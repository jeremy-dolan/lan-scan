        "wsd_services": sorted(d.wsd_services),
        "wsd_xaddrs": sorted(d.wsd_xaddrs),
        "wsd_endpoint_ref": d.wsd_endpoint_ref,
        "wsd_manufacturer": d.wsd_manufacturer,
