        "wsd_friendly_name": d.wsd_friendly_name,
        "netbios_name": d.netbios_name,
        "netbios_workgroup": d.netbios_workgroup,
        # JSON keys are always strings; cast port ints back when loading.
        "http_banners": {str(p): v for p, v in d.http_banners.items()},
        "http_probe_results": {str(p): v for p, v in d.http_probe_results.items()},
        "leaked_macs": d.leaked_macs,
        "location_urls": sorted(d.location_urls),
        "xml_data_b64_by_url": {
            url: base64.b64encode(body).decode("ascii")
            for url, body in d.xml_data.items()
        },
        "is_new": d.is_new,
    }


def _device_from_dict(data: dict) -> "Device":
    """Inverse of _device_to_dict."""
    xml_data = {
        url: base64.b64decode(b64)
        for url, b64 in (data.get("xml_data_b64_by_url") or {}).items()
        if b64
    }
    return Device(
        address=data["address"],
        model=data.get("model"),
        ssdp_services=set(data.get("ssdp_services") or []),
        mdns_services=set(data.get("mdns_services") or []),
        xml_data=xml_data,
        mac_address=data.get("mac_address"),
        oui_registrant=data.get("oui_registrant"),
        txt_records=dict(data.get("txt_records") or {}),
        rdns_name=data.get("rdns_name"),
        mdns_a_name=data.get("mdns_a_name"),
        mdns_srv_name=data.get("mdns_srv_name"),
        mdns_instance_name=data.get("mdns_instance_name"),
