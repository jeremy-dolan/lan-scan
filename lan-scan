            stdscr.attroff(curses.color_pair(2) | curses.A_BOLD)
        except curses.error:
            pass

        lines = _help_lines()
        max_scroll = max(0, len(lines) - content_height)
        self.help_scroll = min(self.help_scroll, max_scroll)

        for i, line in enumerate(lines[self.help_scroll:self.help_scroll + content_height]):
            row = content_top + i
            try:
                is_section = line.startswith("── ")
                if is_section:
                    stdscr.attron(curses.color_pair(2))
                stdscr.addnstr(row, content_left, line[:content_w], content_w)
                if is_section:
                    stdscr.attroff(curses.color_pair(2))
            except curses.error:
                pass

        # Footer drawn on the bottom border of the popup
        if len(lines) <= content_height:
            footer = " ? / ENTER / q / ESC: back "
        else:
            scroll_info = f"{self.help_scroll + 1}-{min(self.help_scroll + content_height, len(lines))}/{len(lines)}"
            footer = f" Line {scroll_info} | PgUp/PgDn: scroll | ? / ENTER / q / ESC: back "
        footer_col = left + max(1, (box_w - len(footer)) // 2)
        try:
            stdscr.attron(curses.color_pair(2) | curses.A_BOLD)
            stdscr.addnstr(bottom, footer_col, footer, box_w - 2)
            stdscr.attroff(curses.color_pair(2) | curses.A_BOLD)
        except curses.error:
            pass

        stdscr.refresh()


def setup_sudoers() -> int:
    """Print the sudoers entry needed for passwordless nmap ARP scanning."""
    import getpass

    nmap_path = shutil.which("nmap")
    if not nmap_path:
        print("nmap not found in PATH. Install it first:")
        print("    brew install nmap")
        return 1

    subnet = NetworkDiscovery()._arp_sweep_subnet()
    if not subnet:
        print("Could not determine local subnet (no network connection?).")
        return 1

    user = getpass.getuser()
    entry = f"{user} ALL=(root) NOPASSWD: {nmap_path} -sn -PR -oG - {subnet}"
    sudoers_file = "/etc/sudoers.d/lan-scan"

    print("To enable active ARP discovery without password prompts, add this sudoers entry:")
    print()
    print(f"  {entry}")
    print()
    print(f"This can be placed in, e.g.: {sudoers_file}")
    print()
    print(f"Note: {subnet} is hardcoded into this authorization, so other subnets")
    print("will still require manual authorization (or re-run --setup-sudoers).")
    return 0


def _arp_sudo_status(discovery: "NetworkDiscovery") -> str:
    """Silent check of whether the ARP-scan sudo invocation is already authorized.

    Returns:
      'ok'     — cached creds or NOPASSWD entry; sudo will not prompt.
      'prompt' — sudo would prompt for a password; caller may decide whether
                 to interactively prompt now.
      'skip'   — nothing to authorize (nmap not installed, or no local subnet).
                 ARP scan will be skipped regardless.
    """
    nmap_path = shutil.which("nmap")
    if not nmap_path:
        return 'skip'
    subnet = discovery._arp_sweep_subnet()
    if not subnet:
        return 'skip'
    # Test the exact command we'll run, without prompting. Matches both
    # NOPASSWD entries and valid cached creds.
    cmd = [nmap_path, "-sn", "-PR", "-oG", "-", subnet]
    result = subprocess.run(
        ["sudo", "-n", "-l"] + cmd,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        timeout=5,
    )
    return 'ok' if result.returncode == 0 else 'prompt'


def check_and_authorize_sudo(discovery: "NetworkDiscovery") -> None:
    """If sudo for the ARP scan isn't already authorized, prompt the user
    interactively (in cooked terminal mode) to authorize it. No-op when
    already authorized or when there's nothing to authorize."""
    if _arp_sudo_status(discovery) != 'prompt':
        return

    nmap_path = shutil.which("nmap")
    subnet = discovery._arp_sweep_subnet()

    print()
    print("Active ARP discovery (recommended) requires sudo to run the command:")
    print(f"    sudo {nmap_path} -sn -PR -oG - {subnet}")
    print()
    print("For permanent passwordless setup, run:")
    print(f"    python3 {sys.argv[0]} --setup-sudoers")
    print()
    try:
        response = input("Authorize sudo now? [Y/n] (will prompt for password) ").strip().lower()
    except EOFError:
        response = ""
    except KeyboardInterrupt:
        print()
        sys.exit(130)

    if response == "n":
        print("ARP scan will be skipped.")
        print()
        return

    # Cache credentials interactively (no command runs, just updates sudo timestamp)
    subprocess.run(["sudo", "-v"])
    print()


def _startup_menu(stdscr, history: list[dict]) -> Optional[tuple[str, Optional[dict]]]:
    """Curses startup menu: 'New scan' followed by a list of historic scans.

    Returns ('new', None), ('load', history_entry), or None to exit."""
    curses.set_escdelay(50)
    curses.curs_set(0)
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_BLACK, curses.COLOR_WHITE)  # Selected
    curses.init_pair(2, curses.COLOR_CYAN, -1)                   # Header / separator / footer

    # items: (kind, label, payload) where kind ∈ {"new", "separator", "history"}
    items: list[tuple[str, str, Optional[dict]]] = [("new", "New scan", None)]
    if history:
        items.append(("separator", "", None))
        for entry in history:
            label = _run_summary(entry["n_devices"], entry["subnet"], entry["timestamp"], align=True)
            items.append(("history", label, entry))

    selectable = [i for i, item in enumerate(items) if item[0] != "separator"]
    cur = 0  # index into `selectable`

    while True:
        stdscr.clear()
        height, width = stdscr.getmaxyx()

        stdscr.attron(curses.color_pair(2) | curses.A_BOLD)
        stdscr.addnstr(0, 0, "lan-scan", width - 1)
        stdscr.attroff(curses.color_pair(2) | curses.A_BOLD)

        for i, (kind, text, _) in enumerate(items):
            row = i + 2
            if row >= height - 1:
                break
            try:
                if kind == "separator":
                    stdscr.attron(curses.color_pair(2))
                    stdscr.addnstr(row, 0, "─" * (width - 1), width - 1)
                    stdscr.attroff(curses.color_pair(2))
                elif selectable[cur] == i:
                    stdscr.attron(curses.color_pair(1))
                    stdscr.addnstr(row, 0, text.ljust(width - 1), width - 1)
                    stdscr.attroff(curses.color_pair(1))
                else:
                    stdscr.addnstr(row, 0, text, width - 1)
            except curses.error:
                pass

        footer = " UP/DOWN: navigate │ ENTER: select │ q/ESC: quit "
        try:
            stdscr.attron(curses.color_pair(2))
            stdscr.addnstr(height - 1, 0, footer.center(width - 1), width - 1)
            stdscr.attroff(curses.color_pair(2))
        except curses.error:
            pass

        stdscr.refresh()

        try:
            key = stdscr.getch()
        except KeyboardInterrupt:
            return None

        if key in (ord('q'), 27, 3):  # q, ESC, Ctrl-C (raw mode safety)
            return None
        elif key in (curses.KEY_UP, ord('k')):
            cur = max(0, cur - 1)
        elif key in (curses.KEY_DOWN, ord('j')):
            cur = min(len(selectable) - 1, cur + 1)
        elif key in (10, 13, curses.KEY_ENTER):
            kind, _, payload = items[selectable[cur]]
            if kind == "new":
                return ("new", None)
            if kind == "history":
                return ("load", payload)
        elif key == curses.KEY_RESIZE:
            stdscr.clear()


