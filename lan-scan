  --new-scan          Run a new scan in the TUI (skips the new/previous prompt).
  --load-previous     Load the previously-saved scan in the TUI (skips the
                      prompt). Exits 1 if there is no saved scan.
  --print             Run a scan and print results to stdout (no TUI, no
                      interactive prompt). Saves the run like the TUI does.
  --print-previous    Print the previously-saved scan (no scan, no TUI, no
                      save). Exits 1 if there is no saved scan.
  --setup-sudoers     Print the sudoers entry needed for passwordless ARP
                      discovery via nmap.

Default (no options): interactive prompt for new scan vs. load previous, then
the curses TUI.
"""


def _run_new_scan_tui(previous: Optional[dict]) -> None:
    discovery = NetworkDiscovery()
    current_subnet = discovery._get_local_subnet()
    ensure_manuf()

    # Diff against the previous run only if the subnet matches
    if previous and previous.get("subnet") == current_subnet:
        discovery._pending_diff = previous

    check_and_authorize_sudo(discovery)

    ui = CursesUI(discovery)
    try:
        curses.wrapper(ui.run)
    except KeyboardInterrupt:
        # Abort path: deliberately do NOT save. The previous run's JSON stays
        # on disk so --load-previous still recalls the prior good snapshot.
        sys.exit(130)
    save_run(discovery.devices.values(), current_subnet, discovery.missing_devices)


def _load_previous_tui(previous: Optional[dict]) -> None:
    if not previous:
        print("No previous scan on file.", file=sys.stderr)
        sys.exit(1)
    discovery = NetworkDiscovery()
    discovery.load_from(previous)
    ui = CursesUI(discovery, review_timestamp=previous.get("timestamp"))
    try:
        curses.wrapper(ui.run)
    except KeyboardInterrupt:
        sys.exit(130)
    # Don't overwrite the saved file in review mode.


_MODE_FLAGS = (
    "--setup-sudoers",
    "--print",
    "--print-previous",
    "--new-scan",
    "--load-previous",
)


def main():
    if "--help" in sys.argv or "-h" in sys.argv:
        print(USAGE, end="")
        return

    selected = [f for f in _MODE_FLAGS if f in sys.argv]
    if len(selected) > 1:
        print(
            f"Conflicting flags: {', '.join(selected)}. Pick one.",
            file=sys.stderr,
        )
        sys.exit(2)

    if "--setup-sudoers" in sys.argv:
        sys.exit(setup_sudoers())

    if "--print-previous" in sys.argv:
        previous = load_previous_run()
        if not previous:
            print("No previous scan on file.", file=sys.stderr)
            sys.exit(1)
        discovery = NetworkDiscovery()
        discovery.load_from(previous)
        ts = previous.get("timestamp", "unknown time")
        print(f"Previous scan from {ts}")
        discovery.print_results()
        return

    if "--print" in sys.argv:
        discovery = NetworkDiscovery()
        current_subnet = discovery._get_local_subnet()
        ensure_manuf()
        check_and_authorize_sudo(discovery)
        def _print_progress(msg, key=None, final=False):
            # On a plain stdout we can't rewrite lines, so drop the intermediate
            # live ticks (keyed, non-final) and print only settled stage lines.
            if key is None or final:
                print(msg)
        try:
            asyncio.run(discovery.discover(timeout=3.0, on_progress=_print_progress))
        except KeyboardInterrupt:
            sys.exit(130)
        discovery.print_results()
        save_run(discovery.devices.values(), current_subnet, discovery.missing_devices)
        return

    if "--load-previous" in sys.argv:
        _load_previous_tui(load_previous_run())
        return

    if "--new-scan" in sys.argv:
        _run_new_scan_tui(load_previous_run())
        return

    history = list_history()
    # ensure_manuf may print to the terminal on first run, so it must run in
    # cooked mode before curses opens. The sudo check is deferred: it's only
    # relevant if the user picks "New scan", and we want to avoid prompting
    # at all when they're just reviewing a past scan.
    ensure_manuf()

    # _menu_session returns:
    #   None                                      — user quit, or load completed
    #   ('scan_done',          discovery, subnet) — new-scan ran in this session
    #   ('scan_after_prompt',  discovery, subnet) — new-scan deferred so the
    #                                                outer caller can prompt for
    #                                                sudo in cooked mode, then
    #                                                re-enter curses to scan.
    def _menu_session(stdscr):
        choice = _startup_menu(stdscr, history)
        if choice is None:
            return None
        action, payload = choice
        # Wipe the menu so the next view's first paint isn't drawn over it.
        stdscr.erase()
        stdscr.refresh()
        if action == "load":
            data = load_run(payload["path"])
            if not data:
                return None
            discovery = NetworkDiscovery()
            discovery.load_from(data)
            CursesUI(discovery, review_timestamp=data.get("timestamp")).run(stdscr)
            return None
        # action == "new"
        discovery = NetworkDiscovery()
        current_subnet = discovery._get_local_subnet()
        if history:
            previous = load_run(history[0]["path"])
            if previous and previous.get("subnet") == current_subnet:
                discovery._pending_diff = previous
        if _arp_sudo_status(discovery) == 'prompt':
            # Need to ask the user for a password — must happen in cooked
            # terminal mode, so bail out of curses and let the caller run
            # the prompt + a fresh curses session for the scan.
            return ('scan_after_prompt', discovery, current_subnet)
        # Sudo is already authorized (or nothing to authorize) — run the
        # scan in this same curses session, no flash.
        CursesUI(discovery).run(stdscr)
        return ('scan_done', discovery, current_subnet)

    try:
        result = curses.wrapper(_menu_session)
    except KeyboardInterrupt:
        sys.exit(130)

    if result is None:
        return

    kind, discovery, current_subnet = result
    if kind == 'scan_after_prompt':
        check_and_authorize_sudo(discovery)
        try:
            curses.wrapper(CursesUI(discovery).run)
        except KeyboardInterrupt:
            sys.exit(130)

    save_run(discovery.devices.values(), current_subnet, discovery.missing_devices)


if __name__ == "__main__":
    main()
