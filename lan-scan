class CursesUI:
    def __init__(self, discovery: NetworkDiscovery, review_timestamp: Optional[str] = None):
        self.discovery = discovery
        self.devices: list[Device] = []
        self.selected = 0
        self.scroll_offset = 0
        self.detail_scroll = 0
        self.showing_detail = False
        self.showing_help = False
        self.help_scroll = 0
        # When set, skip live discovery and just browse pre-loaded devices.
        self.review_timestamp = review_timestamp
        # Set when a live scan finishes; feeds the status bar's "at <time>".
        self.scan_timestamp: Optional[str] = None

    def run(self, stdscr):
        curses.set_escdelay(50)  # Default 1000ms feels laggy; 50ms is snappy.
        curses.curs_set(0)  # Hide cursor
        curses.use_default_colors()

        # Initialize color pairs
        curses.init_pair(1, curses.COLOR_BLACK, curses.COLOR_WHITE)  # Selected
        curses.init_pair(2, curses.COLOR_CYAN, -1)  # Header / separators
        curses.init_pair(3, curses.COLOR_YELLOW, -1)  # Accent
        curses.init_pair(4, curses.COLOR_GREEN, -1)  # New device (since last run)
        curses.init_pair(5, curses.COLOR_BLACK, curses.COLOR_GREEN)  # Selected + new

        stdscr.clear()
        stdscr.attron(curses.color_pair(2) | curses.A_BOLD)
        if self.review_timestamp:
            header = f"Reviewing previous scan from {self.review_timestamp}"
        else:
            header = "Scanning..."
        stdscr.addstr(0, 0, header)
        stdscr.attroff(curses.color_pair(2) | curses.A_BOLD)
        stdscr.refresh()

        line = [2]  # mutable so the closure can advance it
        rows: dict[str, int] = {}  # progress key -> screen row, for in-place updates

        def progress(msg: str, key=None, final=False):
            # A keyed message rewrites its previous row in place (live per-stage
            # counters); an unkeyed one appends a new line. `final` is only
            # meaningful to plain-stdout consumers, so it's ignored here.
            if key is not None and key in rows:
                row = rows[key]
            else:
                row = line[0]
                line[0] += 1
                if key is not None:
                    rows[key] = row
            try:
                stdscr.move(row, 0)
                stdscr.clrtoeol()  # clear stale text when the new line is shorter
                stdscr.addstr(row, 0, msg)
            except curses.error:
                pass
            stdscr.refresh()

        if self.review_timestamp:
            # Skip the live scan; self.discovery is already populated.
            n = len(self.discovery.devices)
            progress(f"Loaded {n} {plural(n, 'device')} from cache.")
        else:
            asyncio.run(self.discovery.discover(timeout=3.0, on_progress=progress))
            self.scan_timestamp = datetime.now().isoformat(timespec="seconds")

        # Diff against previous run, if available (skipped in review mode —
        # there's no "previous" relative to a static cached snapshot).
        if not self.review_timestamp:
            previous = getattr(self.discovery, "_pending_diff", None)
            if previous is not None:
                self.discovery.apply_diff(previous)

        # Sort devices by IP
        self.devices = sorted(
            self.discovery.devices.values(),
            key=lambda d: tuple(map(int, d.address.split(".")))
        )

        line[0] += 1
        if not self.devices:
            stdscr.addstr(line[0], 0, "No devices found. Press any key to exit.")
            stdscr.refresh()
            stdscr.getch()
            return

        # Quick confirmation gate before opening the device list, so scan
        # results stay visible long enough for the user to glance at the
        # per-stage counts. Skipped in review mode (no scan was just shown).
        if not self.review_timestamp:
            stdscr.attron(curses.color_pair(3) | curses.A_BOLD)
            stdscr.addstr(
                line[0], 0,
                f"Found {len(self.devices)} {plural(len(self.devices), 'device')}. "
                "Press ENTER to view, q to quit.",
            )
            stdscr.attroff(curses.color_pair(3) | curses.A_BOLD)
            stdscr.refresh()

            while True:
                k = stdscr.getch()
                if k in (10, 13, curses.KEY_ENTER):
                    break
                if k in (ord('q'), 27):
                    return

        # Main loop
        while True:
            # The list is drawn every iteration so the popups overlay it.
            self._draw_list(stdscr)
            if self.showing_detail:
                self._draw_detail(stdscr)
            if self.showing_help:
                self._draw_help(stdscr)

            key = stdscr.getch()

            # Help is modal — handle its keys exclusively while open.
            if self.showing_help:
                if key in (ord('q'), 27, ord('?'), ord('\n'), curses.KEY_ENTER):
                    self.showing_help = False
                    self.help_scroll = 0
                elif key in (curses.KEY_UP, ord('k')):
                    self.help_scroll = max(0, self.help_scroll - 1)
                elif key in (curses.KEY_DOWN, ord('j')):
                    self.help_scroll += 1  # clamped in _draw_help
                elif key == curses.KEY_PPAGE:
                    page = max(1, stdscr.getmaxyx()[0] - 3)
                    self.help_scroll = max(0, self.help_scroll - page)
                elif key == curses.KEY_NPAGE:
                    page = max(1, stdscr.getmaxyx()[0] - 3)
                    self.help_scroll += page  # clamped in _draw_help
                elif key == curses.KEY_RESIZE:
                    stdscr.clear()
                continue

            if key == ord('q') or key == 27:  # q or ESC
                if self.showing_detail:
                    self.showing_detail = False
                    self.detail_scroll = 0
                else:
                    break
            elif key == ord('?'):
                # '?' opens help from the list view. Ignored while a device
                # detail popup is already up — keep one modal layer at a time.
                if not self.showing_detail:
                    self.showing_help = True
                    self.help_scroll = 0
            elif key == curses.KEY_UP:
                if self.showing_detail:
                    self.detail_scroll = max(0, self.detail_scroll - 1)
                else:
                    self.selected = max(0, self.selected - 1)
                    self._adjust_scroll(stdscr)
            elif key == curses.KEY_DOWN:
                if self.showing_detail:
                    self.detail_scroll += 1
                else:
                    self.selected = min(len(self.devices) - 1, self.selected + 1)
                    self._adjust_scroll(stdscr)
            elif key == ord('k'):
                self.selected = max(0, self.selected - 1)
                self.detail_scroll = 0
                self._adjust_scroll(stdscr)
            elif key == ord('j'):
                self.selected = min(len(self.devices) - 1, self.selected + 1)
                self.detail_scroll = 0
                self._adjust_scroll(stdscr)
            elif key == curses.KEY_PPAGE:
                if self.showing_detail:
                    page = max(1, stdscr.getmaxyx()[0] - 3)
                    self.detail_scroll = max(0, self.detail_scroll - page)
            elif key == curses.KEY_NPAGE:
                if self.showing_detail:
                    page = max(1, stdscr.getmaxyx()[0] - 3)
                    self.detail_scroll += page  # clamped to max_scroll in _draw_detail
            elif key == ord('\n') or key == curses.KEY_ENTER:
                if self.showing_detail:
                    self.showing_detail = False
                    self.detail_scroll = 0
                else:
                    self.showing_detail = True
                    self.detail_scroll = 0
            elif key == curses.KEY_RESIZE:
                stdscr.clear()

    def _adjust_scroll(self, stdscr):
        height, _ = stdscr.getmaxyx()
        # Rows 0–1 are the header + rule; the bottom two rows are footers (scan
        # summary + hotkeys).
        list_height = height - 4

        if self.selected < self.scroll_offset:
            self.scroll_offset = self.selected
        elif self.selected >= self.scroll_offset + list_height:
            self.scroll_offset = self.selected - list_height + 1

    def _draw_list(self, stdscr):
        stdscr.clear()
        height, width = stdscr.getmaxyx()

        missing = self.discovery.missing_devices

        # Rows 0–1 — column header + rule; separators at byte positions 16 and 49.
        header = f"{'ADDRESS':<15} │ {'DEVICE':<30} │ NAME"
        rule_chars = ["─"] * (width - 1)
        for col in (16, 49):
            if col < len(rule_chars):
                rule_chars[col] = "┼"
        stdscr.attron(curses.color_pair(2) | curses.A_BOLD)
        stdscr.addnstr(0, 0, header, width - 1)
        stdscr.addnstr(1, 0, "".join(rule_chars), width - 1)
        stdscr.attroff(curses.color_pair(2) | curses.A_BOLD)

        # Build the combined row list: current devices + (optional) missing section
        rows: list[tuple] = [("device", d, i) for i, d in enumerate(self.devices)]
        if missing:
            rows.append(("section", "Missing since last run"))
            for m in missing:
                rows.append(("missing", m))

        # Bottom two rows are footers (scan summary + hotkeys), plus header + rule on top.
        list_height = height - 4
        for i, row_data in enumerate(rows[self.scroll_offset:self.scroll_offset + list_height]):
            screen_row = i + 2
            kind = row_data[0]

            if kind == "section":
                title = row_data[1]
                section_line = f"── {title} " + "─" * max(0, width - 5 - len(title))
                stdscr.attron(curses.color_pair(2))
                stdscr.addnstr(screen_row, 0, section_line, width - 1)
                stdscr.attroff(curses.color_pair(2))
            elif kind == "device":
                self._draw_device_row(stdscr, screen_row, width, row_data[1], row_data[2] == self.selected)
            elif kind == "missing":
                self._draw_missing_row(stdscr, screen_row, width, row_data[1])

        # Footer — suppressed while a popup is open, since the popup has its
        # own footer and the list's "ENTER: details" hint would be misleading
        # in that mode.
        if not self.showing_detail and not self.showing_help:
            # First footer row: what was scanned, the new/missing diff, and when.
            new_count = sum(1 for d in self.devices if d.is_new)
            summary = _run_summary(
                len(self.devices), self.discovery.subnet,
                self.review_timestamp or self.scan_timestamp,
                new=new_count, missing=len(missing),
            )
            stdscr.attron(curses.color_pair(2))
            stdscr.addnstr(height - 2, 0, summary.center(width - 1), width - 1)
            stdscr.attroff(curses.color_pair(2))

            # Second footer row: the hotkeys.
            parts = ["UP/DOWN: navigate", "ENTER: details", "?: help", "q: quit"]
            footer = " " + " │ ".join(parts) + " "
            stdscr.attron(curses.color_pair(2))
            stdscr.addnstr(height - 1, 0, footer.center(width - 1), width - 1)
            stdscr.attroff(curses.color_pair(2))

        stdscr.refresh()

    def _draw_device_row(self, stdscr, row, width, device, is_selected):
        device_kind = resolve_device_kind(device)[:30]
        name = (resolve_name(device) or "")
        max_name_len = width - 50
        if len(name) > max_name_len:
            name = name[:max_name_len - 3] + "..."

        line = f"{device.address:<15} │ {device_kind:<30} │ {name}"

        if is_selected:
            pair = curses.color_pair(5) if device.is_new else curses.color_pair(1)
            stdscr.attron(pair)
            stdscr.addnstr(row, 0, line.ljust(width - 1), width - 1)
            stdscr.attroff(pair)
        else:
            row_attr = curses.color_pair(4) if device.is_new else 0
            segments = [
                (f"{device.address:<15} ", row_attr),
                ("│", curses.color_pair(2)),
                (f" {device_kind:<30} ", row_attr),
                ("│", curses.color_pair(2)),
                (f" {name}", row_attr),
            ]
            col = 0
            for text, attr in segments:
                if col >= width - 1:
                    break
                if attr:
                    stdscr.attron(attr)
                stdscr.addnstr(row, col, text, width - 1 - col)
                if attr:
                    stdscr.attroff(attr)
                col += len(text)

    def _draw_missing_row(self, stdscr, row, width, m: dict):
        # m is a raw saved device dict from the previous run. Rehydrate so the
        # same resolvers feed both current and missing rows.
        ghost = _device_from_dict(m)
        device_kind = resolve_device_kind(ghost)[:30]
        name = (resolve_name(ghost) or "")
        max_name_len = width - 50
        if len(name) > max_name_len:
            name = name[:max_name_len - 3] + "..."
        line = f"{m['address']:<15} │ {device_kind:<30} │ {name}"
        stdscr.attron(curses.A_DIM)
        stdscr.addnstr(row, 0, line, width - 1)
        stdscr.attroff(curses.A_DIM)

    def _draw_detail(self, stdscr):
        # Drawn as a centered popup on top of the existing list — no clear().
        screen_h, screen_w = stdscr.getmaxyx()

        # Popup geometry: leaves a margin so the underlying list peeks around it.
        margin_x = max(2, screen_w // 12)
        margin_y = max(1, screen_h // 10)
        top = margin_y
        left = margin_x
        bottom = screen_h - 1 - margin_y
        right = screen_w - 1 - margin_x
        if bottom - top < 4 or right - left < 20:
            # Terminal too small for a popup — fall back to fullscreen overlay.
            top, left, bottom, right = 0, 0, screen_h - 1, screen_w - 1

        box_w = right - left + 1
        # Content area sits inside the box, leaving 1-row border top/bottom
        # and 1-col padding left/right.
        content_left = left + 2
        content_right = right - 2
        content_w = content_right - content_left + 1
        content_top = top + 1
        content_bottom = bottom - 1
        content_height = content_bottom - content_top + 1

        device = self.devices[self.selected]

        # Draw the popup frame
        try:
            stdscr.attron(curses.color_pair(2))
            stdscr.addstr(top, left, "┌" + "─" * (box_w - 2) + "┐")
            for r in range(top + 1, bottom):
                stdscr.addstr(r, left, "│")
                stdscr.addstr(r, right, "│")
                # Blank the popup interior so list rows behind don't show through.
                stdscr.addstr(r, left + 1, " " * (box_w - 2))
            stdscr.addstr(bottom, left, "└" + "─" * (box_w - 2) + "┘")
            stdscr.attroff(curses.color_pair(2))
        except curses.error:
            pass

        # Title centered on top border
        title = f" Device Details: {device.address} "
        title_col = left + max(1, (box_w - len(title)) // 2)
        try:
            stdscr.attron(curses.color_pair(2) | curses.A_BOLD)
            stdscr.addnstr(top, title_col, title, box_w - 2)
            stdscr.attroff(curses.color_pair(2) | curses.A_BOLD)
        except curses.error:
            pass

        # Build detail lines
        lines = []
        lines.append(f"IP Address: {device.address}")
        if device.mac_address:
            mac_line = f"MAC Address: {device.mac_address}"
            if device.oui_registrant:
                mac_line += f" ({device.oui_registrant})"
            elif _is_locally_administered_mac(device.mac_address):
                # OUI lookup is useless for locally-administered MACs; on a home
                # LAN these are almost always per-SSID privacy randomization
                # (iOS/Android/Windows), with VM/container bridges a distant 2nd.
                mac_line += " (likely randomized)"
            lines.append(mac_line)
        # Per-probe status block — fixed length, so it sits up front as a
        # header. Device kind and Name are downstream of these results, so
        # they appear after.
        lines.append("Probes:")
        lines.extend(_format_probe_status(device))

        lines.append(f"Device: {resolve_device_kind(device)}")
        resolved_name = resolve_name(device)
        if resolved_name:
            lines.append(f"Name: {resolved_name}")

        # Surface every name-like signal we have, in resolve_name's priority
        # order. This makes it obvious which source the resolver picked and
        # what fallback signals exist behind it.
        name_sources: list[tuple[str, Optional[str]]] = [
            ("Roku friendly name",   device.roku_friendly_name),
            ("Sonos room name",      device.upnp_room_name),
            ("UPnP friendly name",   device.upnp_friendly_name),
            ("WSD friendly name",    device.wsd_friendly_name),
            ("IPP printer-info",     device.ipp_info),
            ("mDNS TXT 'fn'",        device.txt_records.get("fn")),
            ("mDNS A record",        device.mdns_a_name),
            ("mDNS instance name",   device.mdns_instance_name),
            ("NetBIOS name",         device.netbios_name),
            ("mDNS SRV target",     device.mdns_srv_name),
            ("Reverse DNS",          device.rdns_name),
        ]
        shown_sources = [(label, val) for label, val in name_sources if val]
        if shown_sources:
            label_w = max(len(label) for label, _ in shown_sources)
            for label, val in shown_sources:
                lines.append(f"  {label:<{label_w}} : {val}")

        if device.netbios_workgroup:
            lines.append(f"NetBIOS Workgroup: {device.netbios_workgroup}")
        # Reply-but-no-names case (e.g. macOS smbd): provenance flags that we
        # got a NetBIOS reply, but the device returned an empty name list.
        if "netbios" in device.provenance and not (device.netbios_name or device.netbios_workgroup):
            lines.append("NetBIOS: replied, no names registered")
        def append_wrapped(prefix: str, items: list[str]):
            """Append `prefix` + comma-separated items, wrapped to fit the
            popup width with continuation lines indented to match the prefix."""
            indent = " " * len(prefix)
            max_line_len = content_w - 2
            current_line = prefix
            first = True
            for item in items:
                addition = item if first else f", {item}"
                if len(current_line) + len(addition) > max_line_len:
                    lines.append(current_line)
                    current_line = indent + item
                else:
                    current_line += addition
                first = False
            if current_line.strip():
                lines.append(current_line)

        def append_txt_record(key: str, value: str):
            """Append a dimmed 'key: value' TXT line, wrapping the value across
            continuation lines so nothing is clipped at the popup edge. Breaks
            after a comma or at a space when possible (TXT values like `pdl` are
            comma-separated lists), and hard-splits any run with no such break.
            Continuation lines keep the dim marker and hang-indent under the key."""
            if not value:
                lines.append(DIM_LINE_MARKER + f"  {key}")
                return
            head = f"  {key}: "
            # Continuation lines hang-indent to align directly under the value, so
            # wrapped text reads as part of the record rather than a new key. Fall
            # back to a small fixed indent if the key is long enough to crowd it.
            cont = " " * len(head) if len(head) <= content_w - 8 else "      "
            avail = max(8, content_w - len(head))
            rest = value
            first = True
            while rest:
                width = avail if first else max(8, content_w - len(cont))
                if len(rest) <= width:
                    chunk, rest = rest, ""
                else:
                    window = rest[:width]
                    comma = window.rfind(",")
                    if comma >= width // 2:      # break just after a comma
                        cut = comma + 1
                    else:
                        # else the rightmost space or '/' (keeps URLs readable);
                        # failing that, a hard split so nothing is dropped.
                        brk = max(window.rfind(" "), window.rfind("/"))
                        cut = brk + 1 if brk >= width // 2 else width
                    chunk, rest = rest[:cut].rstrip(), rest[cut:].lstrip()
                prefix = head if first else cont
                lines.append(DIM_LINE_MARKER + prefix + chunk)
                first = False

        # WS-Discovery services live here as a compact line; mDNS services
        # have moved into the dedicated `── mDNS ──` section below alongside
        # their TXT records. SSDP services are omitted here entirely — when
        # present, they're shown as a hierarchical device/service tree in
        # the UPnP Device Description section below.
        if device.wsd_services:
            append_wrapped("WS-D types:    ", sorted(device.wsd_services))
        # DPWS metadata resolved by the WS-Transfer Get enrichment step.
        wsd_meta = " ".join(
            p for p in (device.wsd_manufacturer, device.wsd_model) if p
        )
        if wsd_meta:
            lines.append(f"WSD model:     {wsd_meta}")
        # IPP Get-Printer-Attributes results (model, admin description/location,
        # live state and any state reasons) — fields with no mDNS equivalent,
        # shown in source order. Keys mirror the snapshot built in enrich_ipp.
        for ipp_label, ipp_key in (("IPP model:     ", "printer-make-and-model"),
                                   ("IPP info:      ", "printer-info"),
                                   ("IPP location:  ", "printer-location"),
                                   ("IPP state:     ", "printer-state"),
                                   ("IPP reasons:   ", "printer-state-reasons")):
            ipp_val = device.ipp_attrs.get(ipp_key)
            if ipp_val:
                lines.append(f"{ipp_label}{ipp_val}")

        # Leaked MACs — hardware MACs the device disclosed via mDNS instance
        # names even when using a randomized MAC on the wire. Show the OUI
        # registrant when we can resolve it.
        for mac, registrant in sorted(device.leaked_macs.items()):
            label = f"Leaked MAC: {mac}"
            if registrant:
                label += f" ({registrant})"
            lines.append(label)

        def section(title: str) -> str:
            # Trailing dashes get truncated to the popup width when drawn
            return f"── {title} " + "─" * max(0, content_w - 4 - len(title))

        # Section order: standard protocols first (UPnP, mDNS, WS-Discovery,
        # HTTP banners), then vendor-specific enrichment probes (Roku ECP,
        # Hue /api/config, plus any future vendor-specific follow-ups).

        # One section per fetched LOCATION URL. A single device often advertises
        # several (rootdevice, MediaServer, MediaRenderer, etc.) and their
        # descriptions can differ — render each rather than collapsing them.
        for url in sorted(device.xml_data):
            lines.append("")
            lines.append(section("UPnP Device Description"))
            lines.append(f" {url}")
            lines.extend(format_xml(device.xml_data[url]))

        # Combined mDNS section: services prominent (normal weight); TXT
        # records dimmed since most keys are device-internal noise
        # (deviceid, public keys, status flags) and the genuinely useful
        # ones (fn, md, model) already feed into the Name resolver above.
        if device.mdns_services or device.txt_records:
            lines.append("")
            lines.append(section("mDNS"))
            if device.mdns_services:
                append_wrapped("Services: ", sorted(device.mdns_services))
            if device.txt_records:
                lines.append(DIM_LINE_MARKER + "TXT records:")
                for key, value in sorted(device.txt_records.items()):
                    append_txt_record(key, value)

        # WS-Discovery endpoint URLs (XAddrs) — the SOAP endpoints the device
        # exposes for follow-up metadata queries (ONVIF GetDeviceInformation, etc).
        if device.wsd_xaddrs:
            lines.append("")
            lines.append(section("WS-Discovery endpoints"))
            for url in sorted(device.wsd_xaddrs):
                lines.append(f"  {url}")

        if device.http_banners:
            lines.append("")
            lines.append(section("HTTP banners"))
            for port in sorted(device.http_banners.keys()):
                banner = device.http_banners[port]
                scheme = "https" if port in (443, 8443) else "http"
                header = f"{scheme}://{device.address}:{port}"
                status = banner.get("status")
                if status:
                    header += f"  [{status}]"
                lines.append(header)
                if banner.get("server"):
                    lines.append(f"  Server: {banner['server']}")
                if banner.get("title"):
                    lines.append(f"  Title:  {banner['title']}")

        if device.roku_info:
            lines.append("")
            lines.append(section("Roku ECP device-info"))
            for key, value in sorted(device.roku_info.items()):
                lines.append(f"{key}: {value}")

        if device.hue_info:
            lines.append("")
            lines.append(section("Hue /api/config"))
            for key, value in sorted(device.hue_info.items()):
                lines.append(f"{key}: {value}")

        # Display with scrolling — clamp scroll and render into the popup body.
        max_scroll = max(0, len(lines) - content_height)
        self.detail_scroll = min(self.detail_scroll, max_scroll)

        for i, line in enumerate(lines[self.detail_scroll:self.detail_scroll + content_height]):
            row = content_top + i
            try:
                is_dim = line.startswith(DIM_LINE_MARKER)
                if is_dim:
                    line = line[len(DIM_LINE_MARKER):]
                is_section = line.startswith("── ")
                # UPnP device-tree nodes (rendered by format_xml) carry the folder
                # icon — render them bold to distinguish containers from services.
                is_device_node = UPNP_DEVICE_ICON in line
                attr = 0
                if is_section:
                    attr = curses.color_pair(2)
                elif is_device_node:
                    attr = curses.A_BOLD
                elif is_dim:
                    attr = curses.A_DIM
                if attr:
                    stdscr.attron(attr)
                stdscr.addnstr(row, content_left, line[:content_w], content_w)
                if attr:
                    stdscr.attroff(attr)
            except curses.error:
                pass

        # Footer drawn on the bottom border of the popup
        if len(lines) <= content_height:
            footer = " j/k: next/prev device | ENTER: close "
        else:
            scroll_info = f"{self.detail_scroll + 1}-{min(self.detail_scroll + content_height, len(lines))}/{len(lines)}"
            footer = f" Line {scroll_info} | j/k: next/prev device | ENTER: close "
        footer_col = left + max(1, (box_w - len(footer)) // 2)
        try:
            stdscr.attron(curses.color_pair(2) | curses.A_BOLD)
            stdscr.addnstr(bottom, footer_col, footer, box_w - 2)
            stdscr.attroff(curses.color_pair(2) | curses.A_BOLD)
        except curses.error:
            pass

        stdscr.refresh()

    def _draw_help(self, stdscr):
