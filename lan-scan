#!/usr/bin/env python3
"""lan-scan — find devices on the local net with mDNS, SSDP, and WS-Discovery

Discovery via ARP, mDNS, SSDP, and WS-Discovery; per-host enrichment via
NetBIOS, UPnP descriptions, WS-Discovery (DPWS) metadata, HTTP banner grabs,
IPP printer attributes, reverse DNS, and a few vendor-specific pokes (e.g.
Roku ECP, Philips Hue)."""

