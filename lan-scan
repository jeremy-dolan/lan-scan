CACHE_DIR = Path.home() / ".cache" / "lan-scan"
MANUF_PATH = CACHE_DIR / "manuf"
MANUF_URL = "https://www.wireshark.org/download/automated/data/manuf"
HISTORY_DIR = CACHE_DIR / "history"
# Cap on retained scans; older runs get pruned after each save so the cache
# directory doesn't grow unboundedly.
HISTORY_MAX = 50

# Floor on the prefix length the nmap ARP sweep will target. The real subnet
# can be much wider (a campus /16 has 65k addresses, nearly all unreachable at
# L2 — an ARP sweep of the full range is pointless and slow), so for wider
# masks we sweep a /22-aligned window around the local IP instead. /22 = 1024
# addresses.
ARP_SWEEP_MAX_PREFIX = 22


@dataclass
class Device:
    address: str
    model: Optional[str] = None
    # Services are tracked by discovery source so we don't collide on identical
    # short names (e.g. SSDP's "MediaRenderer" vs. mDNS's "_mediarenderer._tcp").
    ssdp_services: set[str] = field(default_factory=set)
    mdns_services: set[str] = field(default_factory=set)
    # One entry per fetched LOCATION URL — devices often advertise several
    # (rootdevice, MediaServer, MediaRenderer, etc.) and they don't all return
    # the same document. Keyed by the URL the body came from.
    xml_data: dict[str, bytes] = field(default_factory=dict)
    mac_address: Optional[str] = None
    oui_registrant: Optional[str] = None
    txt_records: dict[str, str] = field(default_factory=dict)
    rdns_name: Optional[str] = None
    # Per-source NAME fields. Each producer writes only its own field; the
    # resolver (see resolve_name) picks one at display time. See the priority
    # documentation on the resolver function itself.
    mdns_a_name: Optional[str] = None        # A record .local hostname
    mdns_srv_name: Optional[str] = None      # SRV target .local hostname
    mdns_instance_name: Optional[str] = None # Instance-name prefix (AirPlay-style)
    upnp_friendly_name: Optional[str] = None # UPnP <friendlyName>
    upnp_room_name: Optional[str] = None     # Sonos <roomName>
    upnp_manufacturer: Optional[str] = None  # UPnP <manufacturer> (used for DEVICE polish)
    upnp_device_type: Optional[str] = None   # UPnP <deviceType> URN (generic category fallback)
    roku_friendly_name: Optional[str] = None # Roku ECP user-device-name / friendly-device-name
    provenance: set[str] = field(default_factory=set)
    location_urls: set[str] = field(default_factory=set)  # SSDP LOCATION URLs to fetch
    roku_info: dict[str, str] = field(default_factory=dict)  # Roku ECP query/device-info
    hue_info: dict[str, str] = field(default_factory=dict)    # Philips Hue /api/config JSON
    # IPP Get-Printer-Attributes (enrich_ipp): naming fields broken out for the
    # resolvers, plus a flat dict of the requested attributes for the detail view.
    ipp_make_and_model: Optional[str] = None  # IPP 'printer-make-and-model'
    ipp_info: Optional[str] = None            # IPP 'printer-info' (admin description)
    ipp_attrs: dict[str, str] = field(default_factory=dict)
    # WS-Discovery (UDP 3702): qualified Types like "tds:Device" (ONVIF camera),
    # "wprt:PrintDeviceType", "pub:Computer" (Windows). XAddrs are SOAP endpoint
    # URLs the device exposes for further metadata queries.
    wsd_services: set[str] = field(default_factory=set)
    wsd_xaddrs: set[str] = field(default_factory=set)
    # DPWS endpoint reference (urn:uuid) from the ProbeMatch/Hello envelope —
    # the logical wsa:To target for the WS-Transfer Get metadata query.
    wsd_endpoint_ref: Optional[str] = None
    # Metadata resolved by querying an XAddr with WS-Transfer Get (enrich_wsd):
    # DPWS ThisModel (Manufacturer/ModelName) and ThisDevice (FriendlyName).
    wsd_manufacturer: Optional[str] = None
    wsd_model: Optional[str] = None          # DPWS <ModelName>
    wsd_friendly_name: Optional[str] = None  # DPWS <FriendlyName>
    # NetBIOS name service (UDP 137): the workstation's unique name (suffix 0x00)
    # and the workgroup it belongs to (suffix 0x00, group flag set).
    netbios_name: Optional[str] = None
    netbios_workgroup: Optional[str] = None
    # HTTP/HTTPS banner grab: port -> {"server": ..., "title": ..., "status": ...}
    http_banners: dict[int, dict[str, str]] = field(default_factory=dict)
    # Per-port outcome of every HTTP banner attempt, even when nothing usable
    # came back. Values: "ok" (HTTP-shaped reply, recorded in http_banners),
    # "non-http" (connected but didn't speak HTTP), "timeout" (no response in
    # time), "closed" (refused or unreachable).
    http_probe_results: dict[int, str] = field(default_factory=dict)
    # MACs leaked through mDNS instance names (e.g. _apple-mobdev2._tcp PTR
    # embeds the real Apple-assigned MAC even when the device is using a
    # randomized MAC at the L2 layer). Value is "<oui_registrant>" or "".
    leaked_macs: dict[str, str] = field(default_factory=dict)
    is_new: bool = False  # not seen in the previous run

    @property
    def services(self) -> set[str]:
        """Combined view of all advertised services, regardless of source."""
        return self.ssdp_services | self.mdns_services | self.wsd_services

    def __str__(self) -> str:
        return f"{self.address:15} | {resolve_device_kind(self):40} | {resolve_name(self) or ''}"


def get_arp_table() -> dict[str, str]:
    """Get ARP table mapping IP addresses to MAC addresses."""
    arp_table = {}
    try:
        result = subprocess.run(["arp", "-a"], capture_output=True, text=True, timeout=5)
        for line in result.stdout.split("\n"):
            # macOS format: "? (192.168.1.1) at aa:bb:cc:dd:ee:ff on en0 ifscope [ethernet]"
            # Linux format: "? (192.168.1.1) at aa:bb:cc:dd:ee:ff [ether] on eth0"
            if " at " in line and "(" in line:
                try:
                    ip_start = line.index("(") + 1
                    ip_end = line.index(")")
                    ip = line[ip_start:ip_end]

                    at_idx = line.index(" at ") + 4
                    mac_part = line[at_idx:].split()[0]
                    # Normalize MAC format to uppercase with colons
                    if mac_part and mac_part != "(incomplete)":
                        mac = mac_part.upper().replace("-", ":")
                        # Ensure each octet is 2 digits
                        parts = mac.split(":")
                        mac = ":".join(p.zfill(2) for p in parts)
                        arp_table[ip] = mac
                except (ValueError, IndexError):
                    continue
    except Exception:
        pass
    return arp_table


def ensure_manuf() -> bool:
    """Download Wireshark's manuf file to the cache on first run.

    Returns True if a usable file is present. Failure is non-fatal — we just
    fall back to the small built-in OUI table.
    """
    if MANUF_PATH.exists():
        return True
    print("Downloading OUI database from Wireshark (~190 KB, one-time)...")
    try:
        CACHE_DIR.mkdir(parents=True, exist_ok=True)
        urllib.request.urlretrieve(MANUF_URL, MANUF_PATH)
        return True
    except Exception as e:
        print(f"  failed: {e}")
        print("  falling back to limited built-in OUI database")
        return False


def _load_manuf() -> tuple[dict, dict, dict]:
    """Parse the manuf file into (MA-L, MA-M, MA-S) dicts keyed by hex prefix.

    MA-L  = 24-bit OUI (default, 6 hex chars)
    MA-M  = 28-bit (7 hex chars)
    MA-S  = 36-bit (9 hex chars)
    """
    ma_l: dict[str, str] = {}
    ma_m: dict[str, str] = {}
    ma_s: dict[str, str] = {}
    try:
        with open(MANUF_PATH, encoding="utf-8", errors="replace") as f:
            for line in f:
                line = line.split("#", 1)[0].strip()
                if not line:
                    continue
                parts = [p for p in line.split("\t") if p]
                if len(parts) < 2:
                    continue
                addr_field, name = parts[0], parts[1].strip()
                if "/" in addr_field:
                    addr, mask_str = addr_field.split("/", 1)
                    try:
                        mask = int(mask_str)
                    except ValueError:
                        continue
                else:
                    addr, mask = addr_field, 24
                hex_addr = addr.upper().replace(":", "").replace("-", "")
                if mask == 24 and len(hex_addr) >= 6:
                    ma_l[hex_addr[:6]] = name
                elif mask == 28 and len(hex_addr) >= 7:
                    ma_m[hex_addr[:7]] = name
                elif mask == 36 and len(hex_addr) >= 9:
                    ma_s[hex_addr[:9]] = name
    except OSError:
        pass
    return ma_l, ma_m, ma_s


_OUI_DB: Optional[tuple[dict, dict, dict]] = None


def _get_oui_db() -> Optional[tuple[dict, dict, dict]]:
    global _OUI_DB
    if _OUI_DB is None and MANUF_PATH.exists():
        _OUI_DB = _load_manuf()
    return _OUI_DB


def lookup_oui_registrant(mac: str) -> Optional[str]:
    """Lookup MAC's manufacturer via the cached Wireshark manuf file."""
    if not mac:
        return None
    hex_mac = mac.upper().replace(":", "").replace("-", "")
    if len(hex_mac) < 6:
        return None

    db = _get_oui_db()
    if db is None:
        return None

    ma_l, ma_m, ma_s = db
    # Try the most specific match first (MA-S, then MA-M, then MA-L)
    if hex_mac[:9] in ma_s:
        return ma_s[hex_mac[:9]]
    if hex_mac[:7] in ma_m:
        return ma_m[hex_mac[:7]]
    if hex_mac[:6] in ma_l:
        return ma_l[hex_mac[:6]]
    return None


def _is_locally_administered_mac(mac: str) -> bool:
    """True if the U/L bit (0x02 of the first octet) is set. Indicates the MAC
    was not assigned out of an IEEE OUI block — typically per-SSID privacy
    randomization on modern clients, but also VM/container bridges and
    hand-set MACs. Not synonymous with 'randomized'."""
    if not mac:
        return False
    try:
        first = int(mac.split(":")[0], 16)
    except (ValueError, IndexError):
        return False
    return bool(first & 0x02)


def clean_mdns_service(name: str) -> str:
    """Strip mDNS-style decoration: '_xxxxx._tcp.local' -> 'xxxxx'."""
    name = name.rstrip(".")
    for suffix in (".local",):
        if name.endswith(suffix):
            name = name[:-len(suffix)]
    for suffix in ("._tcp", "._udp"):
        if name.endswith(suffix):
            name = name[:-len(suffix)]
    if name.startswith("_"):
        name = name[1:]
    return name


_MAC_PATTERN = re.compile(r"(?<![0-9A-Fa-f])([0-9A-Fa-f]{2}(?::[0-9A-Fa-f]{2}){5})(?![0-9A-Fa-f])")

# Identifies strings that are mostly hex-and-punctuation (UUIDs, bare MACs,
# IPv6 fragments) and would be misleading as a device hostname.
_UUID_OR_MAC = re.compile(r"^[0-9A-Fa-f:.\-]{12,}$")

# Trailing run of >= 12 hex chars suggests a UUID-style identifier even when
# preceded by a label (e.g. 'sonosRINCON_7828CAADE7B401400').
_TRAILING_HEX_RUN = re.compile(r"[0-9A-Fa-f]{12,}$")


def _looks_like_uuid_or_mac(s: str) -> bool:
    return bool(_UUID_OR_MAC.match(s) or _TRAILING_HEX_RUN.search(s))


_GENERIC_HTTP_SERVERS = ("nginx", "apache", "lighttpd", "openresty", "iis", "gunicorn", "envoy", "caddy")


def _is_generic_http_server(server: str) -> bool:
    """A bare 'nginx' or 'Apache/2.4' tells us nothing about the device kind."""
    return server.lower().startswith(_GENERIC_HTTP_SERVERS)


def _is_sonos_friendly_junk(s: str) -> bool:
    """Sonos publishes friendlyName as '192.168.1.x - Sonos Play:1 - RINCON_...',
    which is useless as a NAME. The Sonos roomName is the real label and ranks
    above friendlyName in resolve_name, so this filter only kicks in when
    roomName is somehow missing."""
    return " - " in s and "RINCON_" in s


def _printer_model_from_txt(txt: dict[str, str]) -> Optional[str]:
    """Human-readable printer model from standard AirPrint/IPP/Mopria TXT keys.

    These keys are defined by Apple's Bonjour Printing Specification and reused
    by IPP Everywhere (PWG 5100.14) and Mopria, so they're cross-vendor — every
    AirPrint/Mopria printer (HP, Canon, Epson, Brother, Lexmark, ...) advertises
    them, not just Brother. Priority:
        1. 'ty'                  the spec's human-readable display name
        2. 'usb_MFG'+'usb_MDL'   IEEE-1284 Device ID manufacturer + model
        3. 'product'             the PPD Product string (parenthesized by convention)
    """
    ty = (txt.get("ty") or "").strip()
    if ty:
        return ty
    mdl = (txt.get("usb_MDL") or "").strip()
    if mdl:
        mfg = (txt.get("usb_MFG") or "").strip()
        # usb_MDL sometimes already carries the brand; avoid "Brother Brother ...".
        if mfg and mfg.lower() not in mdl.lower():
            return f"{mfg} {mdl}"
        return mdl
    product = (txt.get("product") or "").strip().strip("()").strip()
    if product:
        return product
    return None


# HomeKit Accessory Protocol category identifiers (HAP spec "Accessory
# Categories"), advertised as the `ci` key in `_hap._tcp` TXT records. This is
# a standardized, cross-vendor device-category enum, so it makes a useful
# DEVICE fallback for HomeKit gear that gives us nothing more specific.
_HAP_CATEGORIES = {
    1: "accessory", 2: "bridge", 3: "fan", 4: "garage door opener",
    5: "light", 6: "lock", 7: "outlet", 8: "switch", 9: "thermostat",
    10: "sensor", 11: "security system", 12: "door", 13: "window",
    14: "window covering", 15: "programmable switch", 16: "range extender",
    17: "IP camera", 18: "video doorbell", 19: "air purifier", 20: "heater",
    21: "air conditioner", 22: "humidifier", 23: "dehumidifier", 26: "speaker",
    28: "sprinkler", 29: "faucet", 30: "shower system", 32: "television",
    33: "remote", 34: "Wi-Fi router", 35: "audio receiver",
    36: "TV set-top box", 37: "TV streaming stick",
}


def _hap_category_from_txt(txt: dict[str, str]) -> Optional[str]:
    """Map a HomeKit `ci` accessory-category integer to a display label."""
    ci = txt.get("ci")
    if not ci:
        return None
    try:
        label = _HAP_CATEGORIES.get(int(ci))
    except ValueError:
        return None
    if not label or label == "accessory":
        return "HomeKit accessory"
    return f"HomeKit {label}"


def _unverified_tls_context():
    """A TLS context that accepts any certificate. LAN devices (printers,
    cameras, NAS) almost universally present self-signed certs with mismatched
    hostnames, so verification would reject nearly all of them — and we only
    want to read public banners/metadata, not establish authenticated trust
    (the tradeoff: no MITM protection, irrelevant for read-only enumeration).
    `ssl` is imported lazily so a Python build compiled without it still runs;
    TLS probes just fail closed."""
    import ssl
    ctx = ssl.create_default_context()
    ctx.check_hostname = False
    ctx.verify_mode = ssl.CERT_NONE
    return ctx


def _xml_first_localname(body: str, tag: str) -> Optional[str]:
    """First non-empty text of an element matched by local name only, ignoring
    the (varying) namespace prefix — e.g. <wsdp:ModelName>, <dpws:ModelName>.
    Used to scrape DPWS metadata without a namespace-aware parser, mirroring
    the regex approach already used for WS-Discovery Types/XAddrs."""
    pat = re.compile(rf"<(?:[\w.-]+:)?{tag}\b[^>]*>([^<]+)</(?:[\w.-]+:)?{tag}>", re.DOTALL)
    for m in pat.finditer(body):
        text = m.group(1).strip()
        if text:
            return text
    return None


# Operational state of a printer, from the IPP `printer-state` enum (RFC 8011).
_IPP_PRINTER_STATES = {3: "idle", 4: "processing", 5: "stopped"}


def _build_ipp_get_printer_attributes(printer_uri: str) -> bytes:
    """Encode a minimal IPP/1.1 Get-Printer-Attributes request (RFC 8010).

    Layout: 2-byte version (1.1), 2-byte operation-id (0x000B), 4-byte
    request-id, then the required operation-attributes group (charset,
    natural-language, printer-uri) plus a `requested-attributes` set limiting
    the reply to the few naming/status fields we care about, terminated by the
    end-of-attributes tag. IPP/1.1 is requested for the widest device support."""
    def attr(value_tag: int, name: str, value: bytes) -> bytes:
        return (bytes([value_tag]) + struct.pack(">H", len(name)) + name.encode()
                + struct.pack(">H", len(value)) + value)

    out = bytearray()
    out += struct.pack(">BBHI", 1, 1, 0x000B, 1)   # version 1.1, Get-Printer-Attributes, req-id 1
    out += bytes([0x01])                            # operation-attributes-tag
    out += attr(0x47, "attributes-charset", b"utf-8")            # 0x47 charset
    out += attr(0x48, "attributes-natural-language", b"en")      # 0x48 naturalLanguage
    out += attr(0x45, "printer-uri", printer_uri.encode())       # 0x45 uri
    requested = ["printer-make-and-model", "printer-info", "printer-location",
                 "printer-state", "printer-state-reasons"]
    # 0x44 keyword; a 1setOf is sent as the first value named and the rest as
    # additional values with a zero-length name.
    out += attr(0x44, "requested-attributes", requested[0].encode())
    for extra in requested[1:]:
        out += attr(0x44, "", extra.encode())
    out += bytes([0x03])                            # end-of-attributes-tag
    return bytes(out)


def _decode_ipp_value(tag: int, val: bytes):
    """Decode one IPP attribute value by its syntax tag (RFC 8010 §3.5.2)."""
    if tag in (0x21, 0x23):                         # integer, enum
        return struct.unpack(">i", val)[0] if len(val) == 4 else None
    if tag == 0x22:                                 # boolean
        return bool(val[0]) if val else None
    if tag in (0x35, 0x36):                         # text/nameWithLanguage
        try:
            lang_len = struct.unpack(">H", val[0:2])[0]
            toff = 2 + lang_len
            text_len = struct.unpack(">H", val[toff:toff + 2])[0]
            return val[toff + 2:toff + 2 + text_len].decode("utf-8", "ignore")
        except Exception:
            return val.decode("utf-8", "ignore")
    # Everything else we request is a text-shaped syntax (textWithoutLanguage
    # 0x41, keyword 0x44, uri 0x45, ...) — decode as a string.
    return val.decode("utf-8", "ignore")


def _parse_ipp_response(data: bytes) -> dict[str, list]:
    """Walk an IPP response body into {attribute-name: [values]} (RFC 8010).

    Tags 0x00–0x0F are delimiter/group tags (0x03 = end-of-attributes); tags
    0x10+ are value tags. A value with a zero-length name is an additional
    member of the preceding attribute's set."""
    attrs: dict[str, list] = {}
    if len(data) < 8:
        return attrs
    pos = 8  # skip 2-byte version + 2-byte status-code + 4-byte request-id
    current = None
    while pos < len(data):
        tag = data[pos]
        pos += 1
        if tag <= 0x0F:                  # delimiter / group tag
            if tag == 0x03:              # end-of-attributes
                break
            current = None
            continue
        if pos + 2 > len(data):
            break
        name_len = struct.unpack(">H", data[pos:pos + 2])[0]
        pos += 2
        name = data[pos:pos + name_len].decode("utf-8", "ignore")
        pos += name_len
        if pos + 2 > len(data):
            break
        val_len = struct.unpack(">H", data[pos:pos + 2])[0]
        pos += 2
        val = data[pos:pos + val_len]
        pos += val_len
        name = current if name_len == 0 else name
        if not name:
            continue
        current = name
        attrs.setdefault(name, []).append(_decode_ipp_value(tag, val))
    return attrs


def resolve_name(device: "Device") -> Optional[str]:
    """Pick the best user-set name (the device's identity) for the NAME column.

    Priority (highest first):
        1. Roku ECP user-device-name      explicitly user-set in Roku settings
        2. Sonos roomName                 explicitly user-set room name
        3. UPnP friendlyName              usually user-set; Sonos junk filtered
        4. DPWS ThisDevice FriendlyName   WS-Discovery metadata (printers, PCs,
                                          cameras); peer of UPnP friendlyName
        5. IPP 'printer-info'             admin-set printer description (enrich_ipp);
                                          no mDNS equivalent
        6. mDNS TXT 'fn'                  printer friendly name (AirPrint, IPP)
        7. mDNS A record host             system hostname (e.g. MacBookAir.local)
        8. mDNS instance prefix           AirPlay-style device name
        9. NetBIOS workstation name       Windows install name (UPPER, 15 chars)
       10. mDNS SRV target host           last-resort mDNS-derived name
       11. Reverse DNS PTR                DHCP-assigned name, sometimes useful

    Explicitly NOT considered: the SSDP `Server:` header (an OS string
    like "Linux/2.6.18", not a device name), and IPP 'printer-location'
    (a "where", surfaced in the detail view but not used as a NAME)."""
    if device.roku_friendly_name:
        return device.roku_friendly_name
    if device.upnp_room_name:
        return device.upnp_room_name
    if device.upnp_friendly_name and not _is_sonos_friendly_junk(device.upnp_friendly_name):
        return device.upnp_friendly_name
    if device.wsd_friendly_name:
        return device.wsd_friendly_name
    if device.ipp_info:
        return device.ipp_info
    fn = device.txt_records.get("fn")
    if fn:
        return fn
    if device.mdns_a_name:
        return device.mdns_a_name
    if device.mdns_instance_name:
        return device.mdns_instance_name
    if device.netbios_name:
        return device.netbios_name
    if device.mdns_srv_name:
        return device.mdns_srv_name
    if device.rdns_name:
        return device.rdns_name
    return None


def _manufacturer_is_redundant(manufacturer: str, model: str) -> bool:
    """True if `model` already conveys the brand. Any shared alphanumeric word
    means the model is probably self-sufficient; matching on whole words to
    avoid substring false positives ("inc" and "Princeton")."""
    mfg_words = set(re.findall(r"[a-z0-9]+", manufacturer.lower()))
    model_words = set(re.findall(r"[a-z0-9]+", model.lower()))
    return bool(mfg_words & model_words)


def resolve_device_kind(device: "Device") -> str:
    """Pick the best identifier (the device's kind) for the DEVICE column.

    Priority (highest first):
        1. UPnP <modelName> (+ <manufacturer> prefix if not redundant)
           — also covers Roku, which surfaces friendly-model-name via device.model
        2. DPWS ThisModel <ModelName> (+ <Manufacturer> prefix)  WS-Discovery
                                           metadata (printers, PCs, cameras)
        3. mDNS TXT 'model' / 'am' / 'md'  Apple model identifiers
        4. Printer TXT 'ty' / 'usb_MDL' / 'product'  cross-vendor AirPrint/IPP/
                                           Mopria model name (see
                                           _printer_model_from_txt)
        5. IPP 'printer-make-and-model'    queried from the printer (enrich_ipp);
                                           the only model source for mDNS-silent
                                           printers reachable on port 631
        6. HTTP Server header              vendor-y software string;
                                           generic web-servers (nginx, Apache,
                                           IIS, lighttpd, ...) are skipped
        7. HomeKit TXT 'ci' category       standardized HAP accessory category
                                           (generic: "HomeKit thermostat")
        8. UPnP <deviceType> URN           generic UPnP category ("MediaServer")
        9. [unknown <OUI registrant> device]   — manufacturer from MAC OUI
       10. [unknown device]                    — locally-administered MAC, or
                                                 OUI lookup failed"""
    if device.model:
        if device.upnp_manufacturer and not _manufacturer_is_redundant(device.upnp_manufacturer, device.model):
            return f"{device.upnp_manufacturer} {device.model}"
        return device.model
    if device.wsd_model:
        mfg = device.wsd_manufacturer
        if mfg and not _manufacturer_is_redundant(mfg, device.wsd_model):
            return f"{mfg} {device.wsd_model}"
        return device.wsd_model
    for key in ("model", "am", "md"):
        v = device.txt_records.get(key)
        if v:
            return v
    printer_model = _printer_model_from_txt(device.txt_records)
    if printer_model:
        return printer_model
    if device.ipp_make_and_model:
        return device.ipp_make_and_model
    for banner in device.http_banners.values():
        server = banner.get("server")
        if server and not _is_generic_http_server(server):
            return server
    hap = _hap_category_from_txt(device.txt_records)
    if hap:
        return hap
    if device.upnp_device_type:
        return _upnp_short(device.upnp_device_type, "device")
    if device.oui_registrant:
        return f"[unknown {device.oui_registrant} device]"
    return "[unknown device]"


def plural(n: int, word: str) -> str:
    return word if n == 1 else word + "s"


def _device_to_dict(d) -> dict:
    """Serialize a Device to a JSON-friendly dict. is_new is persisted so
    review-mode display matches what the user originally saw."""
    return {
        "address": d.address,
        "model": d.model,
        "mac_address": d.mac_address,
        "oui_registrant": d.oui_registrant,
        "ssdp_services": sorted(d.ssdp_services),
        "mdns_services": sorted(d.mdns_services),
        "rdns_name": d.rdns_name,
        "mdns_a_name": d.mdns_a_name,
        "mdns_srv_name": d.mdns_srv_name,
        "mdns_instance_name": d.mdns_instance_name,
        "upnp_friendly_name": d.upnp_friendly_name,
        "upnp_room_name": d.upnp_room_name,
        "upnp_manufacturer": d.upnp_manufacturer,
        "upnp_device_type": d.upnp_device_type,
        "roku_friendly_name": d.roku_friendly_name,
        "provenance": sorted(d.provenance),
        "txt_records": d.txt_records,
        "roku_info": d.roku_info,
        "hue_info": d.hue_info,
        "ipp_make_and_model": d.ipp_make_and_model,
        "ipp_info": d.ipp_info,
