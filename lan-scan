        upnp_device_type=data.get("upnp_device_type"),
        roku_friendly_name=data.get("roku_friendly_name"),
        provenance=set(data.get("provenance") or []),
        location_urls=set(data.get("location_urls") or []),
        roku_info=dict(data.get("roku_info") or {}),
        hue_info=dict(data.get("hue_info") or {}),
        ipp_make_and_model=data.get("ipp_make_and_model"),
        ipp_info=data.get("ipp_info"),
        ipp_attrs=dict(data.get("ipp_attrs") or {}),
        wsd_services=set(data.get("wsd_services") or []),
        wsd_xaddrs=set(data.get("wsd_xaddrs") or []),
        wsd_endpoint_ref=data.get("wsd_endpoint_ref"),
        wsd_manufacturer=data.get("wsd_manufacturer"),
        wsd_model=data.get("wsd_model"),
        wsd_friendly_name=data.get("wsd_friendly_name"),
        netbios_name=data.get("netbios_name"),
        netbios_workgroup=data.get("netbios_workgroup"),
        http_banners={int(p): v for p, v in (data.get("http_banners") or {}).items()},
        http_probe_results={int(p): v for p, v in (data.get("http_probe_results") or {}).items()},
        leaked_macs=dict(data.get("leaked_macs") or {}),
        is_new=bool(data.get("is_new", False)),
    )


def _history_paths() -> list[Path]:
    """All saved runs, newest first (ISO-8601 filenames sort lexicographically)."""
    if not HISTORY_DIR.exists():
        return []
    return sorted(HISTORY_DIR.glob("*.json"), reverse=True)


def _prune_history() -> None:
    """Delete the oldest runs over HISTORY_MAX."""
    for old in _history_paths()[HISTORY_MAX:]:
        try:
            old.unlink()
        except OSError:
            pass


def load_run(path: Path) -> Optional[dict]:
    """Load one saved run by path, or None if unreadable."""
    try:
        with open(path) as f:
            return json.load(f)
    except (json.JSONDecodeError, OSError):
        return None


def list_history() -> list[dict]:
    """Return history metadata newest-first for the startup menu.
    Each entry: {'path': Path, 'timestamp': str, 'subnet': str, 'n_devices': int}."""
    entries = []
    for path in _history_paths():
        data = load_run(path)
        if not data:
            continue
        entries.append({
            "path": path,
            "timestamp": data.get("timestamp") or path.stem,
            "subnet": data.get("subnet") or "?",
            "n_devices": len(data.get("devices") or []),
        })
    return entries


def _friendly_time(iso_ts: Optional[str], pad_hour: bool = False) -> str:
    """Render a saved ISO-8601 timestamp as a friendly absolute time, e.g.
    '1:25 PM, May 26' — or '4:40 PM, Mar 3, 2025' when the year differs from
    the current one. Falls back to the raw string if it doesn't parse.
    With pad_hour, the hour is right-aligned to width 2 (' 1:25' vs '12:49')
    so a column of these lines up; used by the load-scans menu."""
    try:
        dt = datetime.fromisoformat(iso_ts)
    except (ValueError, TypeError):
        return iso_ts or "?"
    hour = dt.hour % 12 or 12
    hour_str = f"{hour:>2}" if pad_hour else str(hour)
    clock = f"{hour_str}:{dt.minute:02d} {'AM' if dt.hour < 12 else 'PM'}"
    date = f"{dt.strftime('%b')} {dt.day}"           # "%-d" isn't portable; build it
    if dt.year != datetime.now().year:
        date += f", {dt.year}"
    return f"{clock}, {date}"


def _run_summary(n_devices: int, subnet: Optional[str], timestamp: Optional[str],
                 new: int = 0, missing: int = 0, align: bool = False) -> str:
    """One-line scan summary shared by the load-scans menu and the TUI status
    bar, e.g. '26 devices (15 new, 11 missing) on 192.168.1.0/24 at 1:25 PM,
    May 26'. The new/missing breakdown is only passed for a live scan. With
    align (the menu's multi-row listing), the device count is right-aligned to
    width 3 and the hour to width 2 so the rows line up into columns."""
    count = f"{n_devices:>3}" if align else str(n_devices)
    summary = f"{count} {plural(n_devices, 'device')}"
    breakdown = []
    if new:
        breakdown.append(f"{new} new")
    if missing:
        breakdown.append(f"{missing} missing")
    if breakdown:
        summary += " (" + ", ".join(breakdown) + ")"
    summary += f" on {subnet or '?'}"
    if timestamp:
        summary += f" at {_friendly_time(timestamp, pad_hour=align)}"
    return summary


def save_run(devices, subnet: Optional[str], missing: Optional[list] = None) -> None:
    """Persist this run's results so the next invocation can diff against it
    and review mode can rehydrate the exact display."""
    if not subnet:
        return
    timestamp = datetime.now().isoformat(timespec="seconds")
    data = {
        "subnet": subnet,
        "timestamp": timestamp,
        "devices": [_device_to_dict(d) for d in devices],
        "missing_devices": missing or [],
    }
    try:
        HISTORY_DIR.mkdir(parents=True, exist_ok=True)
        with open(HISTORY_DIR / f"{timestamp}.json", "w") as f:
            json.dump(data, f, indent=2)
        _prune_history()
    except OSError:
        pass  # cache write is best-effort


def load_previous_run() -> Optional[dict]:
    """Load the most-recent run, or None if no history exists. Used for
    diffing the next scan and as the source for --print-previous /
    --load-previous."""
    runs = _history_paths()
    if not runs:
        return None
    return load_run(runs[0])


class NetworkDiscovery:
    def __init__(self):
        self.devices: dict[str, Device] = {}
        self.arp_table: dict[str, str] = {}
        # Populated by apply_diff(); list of dicts in the same shape as _device_to_dict
        self.missing_devices: list[dict] = []
        self.previous_timestamp: Optional[str] = None
        # The scanned subnet, for the TUI status bar. Set during discover_arp on
        # a live scan, or from the saved run in review mode (load_from).
        self.subnet: Optional[str] = None

    def load_from(self, previous: dict) -> None:
        """Hydrate self.devices from a saved last-run.json dict (review mode)."""
        for d in previous.get("devices", []):
            try:
                device = _device_from_dict(d)
            except Exception:
                continue
            self.devices[device.address] = device
        self.missing_devices = previous.get("missing_devices", []) or []
        self.previous_timestamp = previous.get("timestamp")
        self.subnet = previous.get("subnet")

    def apply_diff(self, previous: dict) -> None:
        """Mark devices not in the previous run as new; record any devices
        that were present last time but not this time."""
        previous_devices = previous.get("devices", [])
        previous_addrs = {d["address"] for d in previous_devices}

        for addr, dev in self.devices.items():
            if addr not in previous_addrs:
                dev.is_new = True

        current_addrs = set(self.devices.keys())
        self.missing_devices = [d for d in previous_devices if d["address"] not in current_addrs]
        self.previous_timestamp = previous.get("timestamp")

    def add_device(
        self,
        address: str,
        service: str = None,
        model: str = None,
        source: str = None,
    ):
        if address not in self.devices:
            self.devices[address] = Device(address)
        device = self.devices[address]
        if service:
            if source == "ssdp":
                device.ssdp_services.add(service)
            elif source == "mdns":
                device.mdns_services.add(service)
            else:
                raise ValueError(
                    f"add_device({address!r}, service={service!r}) requires "
                    f"source='ssdp' or source='mdns', got source={source!r}"
                )
        if model and not device.model:
            device.model = model
        if source:
            device.provenance.add(source)
        return device

    async def discover_mdns(self, timeout: float = 3.0):
        """Discover devices via mDNS (multicast DNS).

        Sends a `_services._dns-sd._udp` meta-query (auto-surfaces every service
        type a responsive device advertises) plus a hand-picked list of common
        types. New service types learned mid-scan get a follow-up PTR query
        sent during the second half of the window so we resolve SRV/TXT/A
        records for service types we hadn't pre-listed."""
        MDNS_ADDR = "224.0.0.251"
        MDNS_PORT = 5353

        # `_services._dns-sd._udp.local` is the standard "list all your
        # advertised types" meta-query.
        meta_query = "_services._dns-sd._udp.local"
        # Seed list of common service types. The meta-query usually surfaces
        # everything, but we keep a hand-picked list as a fallback (some
        # responders historically suppress the meta-query while still answering
        # direct probes — we have no specific device on this network confirmed
        # to do that, but the cost of also sending these is trivial).
        seed_service_types = [
            "_http._tcp.local",
            "_https._tcp.local",
            "_hap._tcp.local",        # HomeKit
            "_homekit._tcp.local",
            "_airplay._tcp.local",
            "_raop._tcp.local",       # AirPlay audio
            "_spotify-connect._tcp.local",
            "_googlecast._tcp.local",
            "_printer._tcp.local",
            "_ipp._tcp.local",
            "_smb._tcp.local",
            "_afpovertcp._tcp.local",
            "_ssh._tcp.local",
            "_sftp-ssh._tcp.local",
            "_device-info._tcp.local",
            "_sonos._tcp.local",
            "_soco._tcp.local",
        ]

        sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM, socket.IPPROTO_UDP)
        sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEPORT, 1)
        sock.bind(("", MDNS_PORT))

        # Join multicast group
        mreq = struct.pack("4sl", socket.inet_aton(MDNS_ADDR), socket.INADDR_ANY)
        sock.setsockopt(socket.IPPROTO_IP, socket.IP_ADD_MEMBERSHIP, mreq)
        sock.setblocking(False)

        # Track which service types we've already queried so meta-query
        # discoveries trigger a single follow-up without re-asking.
        self._mdns_queried_types: set[str] = set()
        self._mdns_new_service_types: set[str] = set()

        async def send_batch(qnames: list[str]):
            """Send each query twice with a 0.3 s gap between passes —
            matches the SSDP/WS-D retry pattern to survive lossy Wi-Fi
            multicast. Runs as a background task while the main loop
            drains responses in parallel."""
            pkts = [self._build_mdns_query(q) for q in qnames]
            for _ in range(2):
                for pkt in pkts:
                    try:
                        sock.sendto(pkt, (MDNS_ADDR, MDNS_PORT))
                    except OSError:
                        pass
                await asyncio.sleep(0.3)

        initial_queries = [meta_query] + list(seed_service_types)
        for q in initial_queries:
            self._mdns_queried_types.add(q)
        initial_task = asyncio.create_task(send_batch(initial_queries))

        # First half of the window: collect responses to seed + meta queries.
        # Then send follow-ups for any *new* service types we learned about
        # via the meta-query. Then collect for the remaining time.
        loop = asyncio.get_running_loop()
        midpoint = loop.time() + (timeout / 2)
        end_time = loop.time() + timeout

        async def drain_until(deadline: float):
            while loop.time() < deadline:
                try:
                    data, addr = sock.recvfrom(4096)
                    self._parse_mdns_response(data, addr[0])
                except BlockingIOError:
                    await asyncio.sleep(0.1)
                except OSError:
                    # Transient receive error (e.g. ICMP unreachable, interface
                    # flap) — keep draining instead of aborting the scan.
                    await asyncio.sleep(0.1)

        await drain_until(midpoint)

        follow_ups = [
            st for st in self._mdns_new_service_types
            if st not in self._mdns_queried_types
        ]
        for st in follow_ups:
            self._mdns_queried_types.add(st)
        self._mdns_new_service_types.clear()
        follow_up_task = (
            asyncio.create_task(send_batch(follow_ups)) if follow_ups else None
        )

        await drain_until(end_time)

        # Both send tasks are bounded (~0.6 s total) and almost always done by
        # now, but await them to ensure no pending sendto fires after close.
        await initial_task
        if follow_up_task:
            await follow_up_task

        sock.close()

    def _build_mdns_query(self, name: str) -> bytes:
        """Build a simple mDNS PTR query."""
        # Header: ID=0, Flags=0, QDCOUNT=1, others=0
        header = struct.pack(">HHHHHH", 0, 0, 1, 0, 0, 0)

        # Question section
        question = b""
        for part in name.split("."):
            question += bytes([len(part)]) + part.encode()
        question += b"\x00"  # End of name
        question += struct.pack(">HH", 12, 1)  # Type PTR, Class IN

        return header + question

    def _parse_mdns_response(self, data: bytes, addr: str):
        """Parse an mDNS response and extract device info from every section.

        Most responses ride SRV/TXT/A records in the ADDITIONAL section
        (alongside the PTR in ANSWER), so we walk all three sections — answer,
        authority, additional — and treat the records identically."""
        try:
            if len(data) < 12:
                return
            qdcount, ancount, nscount, arcount = struct.unpack(">HHHH", data[4:12])
            offset = 12

            # Skip questions
            for _ in range(qdcount):
                _, offset = self._read_name(data, offset)
                offset += 4  # QTYPE + QCLASS

            for _ in range(ancount + nscount + arcount):
                if offset >= len(data):
                    break

                name, offset = self._read_name(data, offset)
                if offset + 10 > len(data):
                    break

                rtype, rclass, ttl, rdlen = struct.unpack(">HHIH", data[offset:offset + 10])
                offset += 10
                if offset + rdlen > len(data):
                    break

                rdata_start = offset
                rdata_end = offset + rdlen

                if rtype == 1 and rdlen == 4:  # A
                    ip = ".".join(str(b) for b in data[rdata_start:rdata_end])
                    if name.endswith(".local"):
                        hostname = name[:-len(".local")]
                        if hostname:
                            device = self.add_device(ip, source="mdns")
                            if not device.mdns_a_name:
                                device.mdns_a_name = hostname

                elif rtype == 12:  # PTR
                    target, _ = self._read_name(data, rdata_start)
                    bare = name.rstrip(".")

                    # Meta-query response: rdata target is a service type to
                    # follow up on later in this scan window.
                    if bare == "_services._dns-sd._udp.local":
                        if target and target not in self._mdns_queried_types:
                            self._mdns_new_service_types.add(target)
                    # Service-type PTRs (and their `<X>._sub.` subtype variants)
                    # always end in `._tcp.local` or `._udp.local`. Anything
                    # else — most commonly reverse-DNS PTRs `*.in-addr.arpa`
                    # and `*.ip6.arpa` that macOS announces per RFC 6762 §11
                    # — is not a service announcement, even though it's also
                    # carried as a PTR record.
                    elif bare.endswith("._tcp.local") or bare.endswith("._udp.local"):
                        service_type = clean_mdns_service(name)
                        if service_type:
                            self.add_device(addr, service=service_type, source="mdns")
                        self._extract_from_mdns_instance(target, addr)

                elif rtype == 33 and rdlen >= 6:  # SRV
                    target, _ = self._read_name(data, rdata_start + 6)
                    if target.endswith(".local"):
                        hostname = target[:-len(".local")]
                        if hostname and not _looks_like_uuid_or_mac(hostname):
                            device = self.add_device(addr, source="mdns")
                            if not device.mdns_srv_name:
                                device.mdns_srv_name = hostname

                elif rtype == 16 and rdlen > 0:  # TXT
                    txt_records = self._parse_txt_record(data[rdata_start:rdata_end])
                    if txt_records and addr in self.devices:
                        self.devices[addr].txt_records.update(txt_records)

                offset = rdata_end

        except Exception:
            pass  # Ignore malformed responses

    def _extract_from_mdns_instance(self, instance: str, addr: str):
        """Extract metadata from a service instance name.

        Apple's `_apple-mobdev2._tcp` PTR instance name embeds the device's real
        Apple-OUI MAC (e.g. `fc:47:d8:b9:1a:39@fe80::...`) even when the device
        is using a randomized MAC at the L2 layer. We capture that as leaked
        metadata without overwriting the actual ARP-layer MAC.

        Also extracts a friendly device name from the instance name prefix
        when it doesn't look like a UUID or bare MAC identifier."""
        if not instance or addr not in self.devices:
            return
        device = self.devices[addr]

        # Embedded MAC (e.g. `fc:47:d8:b9:1a:39@...`)
        for m in _MAC_PATTERN.finditer(instance):
            mac = m.group(1).upper()
            if mac != (device.mac_address or "").upper():
                registrant = lookup_oui_registrant(mac) or ""
                # Don't overwrite a richer registrant with an empty one
                if mac not in device.leaked_macs or registrant:
                    device.leaked_macs[mac] = registrant

        # Friendly name from the instance-name prefix, RAOP-style `MAC@Name`,
        # but skip pure UUIDs (e.g. _remotepairing) and MAC-only prefixes.
        if "._" in instance:
            prefix = instance.split("._", 1)[0]
            if "@" in prefix:
                after = prefix.split("@", 1)[1]
                if after and not _looks_like_uuid_or_mac(after):
                    if not device.mdns_instance_name:
                        device.mdns_instance_name = after
            elif prefix and not _looks_like_uuid_or_mac(prefix):
                if not device.mdns_instance_name:
                    device.mdns_instance_name = prefix

    def _parse_txt_record(self, data: bytes) -> dict[str, str]:
        """Parse TXT record data into key=value pairs."""
        records = {}
        pos = 0
        while pos < len(data):
            length = data[pos]
            if length == 0:
                break
            pos += 1
            if pos + length > len(data):
                break
            txt_str = data[pos:pos + length].decode("utf-8", errors="ignore")
            pos += length
            # Parse key=value format
            if "=" in txt_str:
                key, value = txt_str.split("=", 1)
                records[key] = value
            else:
                # Some TXT records are just flags without values
                records[txt_str] = ""
        return records

    def _read_name(self, data: bytes, offset: int) -> tuple[str, int]:
        """Read a DNS name with compression support."""
        parts = []
        visited = set()

        while offset < len(data):
            if offset in visited:
                break
            visited.add(offset)

            length = data[offset]
            if length == 0:
                offset += 1
                break
            elif length & 0xC0 == 0xC0:
                pointer = struct.unpack(">H", data[offset:offset + 2])[0] & 0x3FFF
                name, _ = self._read_name(data, pointer)
                parts.append(name)
                offset += 2
                break
            else:
                offset += 1
                parts.append(data[offset:offset + length].decode("utf-8", errors="ignore"))
                offset += length

        return ".".join(parts), offset

    async def discover_ssdp(self, timeout: float = 3.0):
        """Discover devices via SSDP (UPnP)."""
        SSDP_ADDR = "239.255.255.250"
        SSDP_PORT = 1900

        # ssdp:all surfaces most UPnP/DIAL devices, but some only answer the
        # narrower upnp:rootdevice query — per netdisco's ssdp.py: "Devices
        # only, some devices will only respond to this query."
        # https://github.com/home-assistant-libs/netdisco/blob/master/netdisco/ssdp.py
        # LOCATION URLs from each response drive the description fetch below.
        search_targets = ["ssdp:all", "upnp:rootdevice"]

        sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM, socket.IPPROTO_UDP)
        sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        sock.setblocking(False)

        # Send each M-SEARCH twice with a small gap — multicast on home Wi-Fi
        # is lossy, and a single dropped packet would silently lose a device.
        async def send_searches():
            for _ in range(2):
                for st in search_targets:
                    message = (
                        "M-SEARCH * HTTP/1.1\r\n"
                        f"HOST: {SSDP_ADDR}:{SSDP_PORT}\r\n"
                        "MAN: \"ssdp:discover\"\r\n"
                        "MX: 2\r\n"
                        f"ST: {st}\r\n"
                        "\r\n"
                    )
                    sock.sendto(message.encode(), (SSDP_ADDR, SSDP_PORT))
                await asyncio.sleep(0.3)

        send_task = asyncio.create_task(send_searches())
        loop = asyncio.get_running_loop()
        end_time = loop.time() + timeout
        while loop.time() < end_time:
            try:
                data, addr = sock.recvfrom(4096)
                self._parse_ssdp_response(data.decode("utf-8", errors="ignore"), addr[0])
            except BlockingIOError:
                await asyncio.sleep(0.1)
            except OSError:
                # Transient receive error — keep draining.
                await asyncio.sleep(0.1)

        await send_task
        sock.close()

    async def discover_wsd(self, timeout: float = 3.0):
        """Discover devices via WS-Discovery (multicast SOAP probe on UDP 3702).

        Fills a coverage gap left by SSDP/mDNS: ONVIF IP cameras, modern Windows
        PCs, and many networked printers/scanners advertise here but not on the
        other multicast protocols. We send a generic Probe (matches any Type)
        and parse ProbeMatch responses for the device's Types + endpoint URLs."""
        WSD_ADDR = "239.255.255.250"
        WSD_PORT = 3702

        sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM, socket.IPPROTO_UDP)
        sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        sock.setblocking(False)

        import uuid
        msg_id = f"uuid:{uuid.uuid4()}"
        probe = (
            '<?xml version="1.0" encoding="utf-8"?>'
            '<soap:Envelope '
            'xmlns:soap="http://www.w3.org/2003/05/soap-envelope" '
            'xmlns:wsa="http://schemas.xmlsoap.org/ws/2004/08/addressing" '
            'xmlns:wsd="http://schemas.xmlsoap.org/ws/2005/04/discovery">'
            '<soap:Header>'
            '<wsa:To>urn:schemas-xmlsoap-org:ws:2005:04:discovery</wsa:To>'
            '<wsa:Action>http://schemas.xmlsoap.org/ws/2005/04/discovery/Probe</wsa:Action>'
            f'<wsa:MessageID>{msg_id}</wsa:MessageID>'
            '</soap:Header>'
            '<soap:Body><wsd:Probe/></soap:Body>'
            '</soap:Envelope>'
        ).encode()

        async def send_probes():
            # Multicast on Wi-Fi is lossy; send twice (matches SSDP / mDNS).
            for _ in range(2):
                try:
                    sock.sendto(probe, (WSD_ADDR, WSD_PORT))
                except OSError:
                    pass
                await asyncio.sleep(0.3)

        send_task = asyncio.create_task(send_probes())
        loop = asyncio.get_running_loop()
        end_time = loop.time() + timeout
        while loop.time() < end_time:
            try:
                data, addr = sock.recvfrom(8192)
                self._parse_wsd_response(data.decode("utf-8", errors="ignore"), addr[0])
            except BlockingIOError:
                await asyncio.sleep(0.1)
            except OSError:
                await asyncio.sleep(0.1)

        await send_task
        sock.close()

    # WS-D Types and XAddrs come back as whitespace-separated lists inside
    # element tags whose namespace prefix varies (wsd:, d:, tns:). We match
    # by local-name only.
    _WSD_TYPES_RE = re.compile(r"<(?:[\w-]+:)?Types[^>]*>([^<]+)</(?:[\w-]+:)?Types>", re.DOTALL)
    _WSD_XADDRS_RE = re.compile(r"<(?:[\w-]+:)?XAddrs[^>]*>([^<]+)</(?:[\w-]+:)?XAddrs>", re.DOTALL)
    # The device's logical endpoint reference — the first <Address> nested in an
    # <EndpointReference> (the device's, not the header's To/ReplyTo). This is
    # the correct wsa:To for a follow-up WS-Transfer Get.
    _WSD_EPR_RE = re.compile(
        r"<(?:[\w-]+:)?EndpointReference\b.*?<(?:[\w-]+:)?Address[^>]*>([^<]+)</(?:[\w-]+:)?Address>",
        re.DOTALL,
    )

    def _parse_wsd_response(self, body: str, addr: str):
        """Extract Types and XAddrs from a WS-D ProbeMatch / Hello envelope.

        Any well-formed WS-D envelope is recorded in provenance even if it
        carries neither Types nor XAddrs — the UI surfaces 'we asked and got
        a reply' separately from 'we got useful metadata back'."""
        if "Envelope" not in body:
            return  # not a WS-D message

        self.add_device(addr, source="wsd")
        device = self.devices[addr]

        m = self._WSD_TYPES_RE.search(body)
        if m:
            for t in m.group(1).split():
                device.wsd_services.add(t)
        m = self._WSD_XADDRS_RE.search(body)
        if m:
            for x in m.group(1).split():
                device.wsd_xaddrs.add(x)
        if not device.wsd_endpoint_ref:
            m = self._WSD_EPR_RE.search(body)
            if m:
                device.wsd_endpoint_ref = m.group(1).strip()

    def _parse_ssdp_response(self, response: str, addr: str):
        """Parse an SSDP M-SEARCH response."""
        lines = response.split("\r\n")
        service = None
        location = None

        for line in lines:
            lower = line.lower()
            if lower.startswith("location:"):
                location = line.split(":", 1)[1].strip()
            elif lower.startswith("st:"):
                target = line.split(":", 1)[1].strip()
                # Vendor-specific STs the URN parser below would miss
                if target == "roku:ecp":
                    service = "roku-ecp"
                # Extract service type from URN
                elif ":" in target:
                    parts = target.split(":")
                    for i, p in enumerate(parts):
                        if p in ("device", "service") and i + 1 < len(parts):
                            service = parts[i + 1]
                            break

        device = self.add_device(addr, service=service, source="ssdp")
        if location and device is not None:
            device.location_urls.add(location)

    async def fetch_device_descriptions(self):
        """Fetch UPnP device descriptions from LOCATION URLs collected during SSDP discovery."""
        tasks = []
        for device in self.devices.values():
            tasks.append(self._fetch_description(device))
        if tasks:
            await asyncio.gather(*tasks, return_exceptions=True)

    # WS-Transfer Get action — the DPWS "fetch your metadata" request.
    _WSD_GET_ACTION = "http://schemas.xmlsoap.org/ws/2004/09/transfer/Get"

    async def enrich_wsd(self):
        """Resolve DPWS device metadata from the WS-Discovery XAddr endpoints
        collected during discovery. A WS-Transfer Get to each XAddr returns the
        device's ThisModel (Manufacturer/ModelName) and ThisDevice
        (FriendlyName) — the Windows/printer/camera analog of the UPnP
        description fetch, reusing endpoints we already discovered."""
        tasks = [
            self._fetch_wsd_metadata(d)
            for d in self.devices.values()
            if d.wsd_xaddrs
        ]
        if tasks:
            await asyncio.gather(*tasks, return_exceptions=True)

    def _build_wsd_get(self, to: str) -> bytes:
        """Build a WS-Transfer Get SOAP 1.2 envelope addressed to `to`."""
        msg_id = f"urn:uuid:{uuid.uuid4()}"
        anon = "http://schemas.xmlsoap.org/ws/2004/08/addressing/role/anonymous"
        envelope = (
            '<?xml version="1.0" encoding="utf-8"?>'
            '<s:Envelope xmlns:s="http://www.w3.org/2003/05/soap-envelope"'
            ' xmlns:a="http://schemas.xmlsoap.org/ws/2004/08/addressing">'
            '<s:Header>'
            f'<a:To>{to}</a:To>'
            f'<a:Action>{self._WSD_GET_ACTION}</a:Action>'
            f'<a:MessageID>{msg_id}</a:MessageID>'
            f'<a:ReplyTo><a:Address>{anon}</a:Address></a:ReplyTo>'
            '</s:Header><s:Body/></s:Envelope>'
        )
        return envelope.encode("utf-8")

    async def _fetch_wsd_metadata(self, device: Device):
        """POST a WS-Transfer Get to each XAddr and scrape DPWS ThisModel /
        ThisDevice metadata. Stops at the first endpoint that yields a model or
        friendly name. wsa:To is the device's endpoint reference when we
        captured one, else the transport URL (tolerated by most stacks)."""
        for xaddr in sorted(device.wsd_xaddrs):
            try:
                parsed = urlparse(xaddr)
                host = parsed.hostname
                port = parsed.port or (443 if parsed.scheme == "https" else 80)
                path = parsed.path or "/"
                if parsed.query:
                    path = f"{path}?{parsed.query}"
                if not host:
                    continue
                envelope = self._build_wsd_get(device.wsd_endpoint_ref or xaddr)
                body = await self._http_post(
                    host, port, path, envelope,
                    "application/soap+xml; charset=utf-8",
                    is_https=(parsed.scheme == "https"),
                )
            except Exception:
                continue
            if not body or b"Envelope" not in body:
                continue
            text = body.decode("utf-8", errors="ignore")
            if not device.wsd_manufacturer:
                device.wsd_manufacturer = _xml_first_localname(text, "Manufacturer")
            if not device.wsd_model:
                device.wsd_model = _xml_first_localname(text, "ModelName")
            if not device.wsd_friendly_name:
                device.wsd_friendly_name = _xml_first_localname(text, "FriendlyName")
            if device.wsd_model or device.wsd_friendly_name:
                return

    async def enrich_roku(self):
        """For devices that look like Rokus, fetch /query/device-info via ECP."""
        tasks = []
        for device in self.devices.values():
            if self._looks_like_roku(device):
                tasks.append(self._fetch_roku_ecp(device))
        if tasks:
            await asyncio.gather(*tasks, return_exceptions=True)

    @staticmethod
    def _looks_like_roku(device: Device) -> bool:
        """Roku self-identifies via the 'roku:ecp' SSDP ST; OUI is the fallback."""
        if "roku-ecp" in device.services:
            return True
        if device.oui_registrant and "roku" in device.oui_registrant.lower():
            return True
        return False

    async def _fetch_roku_ecp(self, device: Device):
        """Fetch the Roku ECP /query/device-info XML and merge fields."""
        try:
            body = await self._http_get(device.address, 8060, "/query/device-info")
        except Exception:
            return
        if not body or b"<device-info" not in body:
            return
        try:
            text = body.decode("utf-8", errors="ignore")
            root = ET.fromstring(text)
        except ET.ParseError:
            return
        for child in root:
            if child.text and child.text.strip():
                device.roku_info[child.tag] = child.text.strip()
        friendly = device.roku_info.get("user-device-name") or device.roku_info.get("friendly-device-name")
        if friendly:
            device.roku_friendly_name = friendly
        model = device.roku_info.get("friendly-model-name") or device.roku_info.get("model-name")
        if model and not device.model:
            device.model = model

    async def enrich_hue(self):
        """For devices that look like Philips Hue bridges, fetch the unauthenticated
        `/api/config` JSON. Returns bridge metadata (model, firmware, API version,
        bridge ID, MAC, etc.) without needing an API key."""
        tasks = []
        for device in self.devices.values():
            if self._looks_like_hue(device):
                tasks.append(self._fetch_hue_config(device))
        if tasks:
            await asyncio.gather(*tasks, return_exceptions=True)

    @staticmethod
    def _looks_like_hue(device: Device) -> bool:
        """Hue bridges advertise `_hue._tcp` via mDNS; OUI ('Philips Lighting'
        / 'Signify') is the fallback."""
        if "hue" in device.mdns_services:
            return True
        if device.oui_registrant:
            registrant = device.oui_registrant.lower()
            if "philips lighting" in registrant or "signify" in registrant:
                return True
        return False

    async def _fetch_hue_config(self, device: Device):
        try:
            body = await self._http_get(device.address, 80, "/api/config")
        except Exception:
            return
        if not body:
            return
        try:
            data = json.loads(body.decode("utf-8", errors="ignore"))
        except (ValueError, UnicodeDecodeError):
            return
        if not isinstance(data, dict):
            return
        # Hue returns plenty of scalar metadata at the top level; skip nested
        # objects (whitelist, swupdate state) that don't render cleanly as a
        # flat key/value table.
        for key, value in data.items():
            if isinstance(value, (str, int, bool)):
                device.hue_info[key] = str(value)

    # Service signals that mark a device as a printer worth an IPP query.
    _PRINTER_MDNS_SERVICES = {"ipp", "ipps", "ipp-tls", "printer", "pdl-datastream"}

    @classmethod
    def _looks_like_printer(cls, device: Device) -> bool:
        """A printer is anything advertising an IPP/printer mDNS service, a WSD
        print device type, or simply listening on the IPP port (631) — the last
        catches printers that are silent on mDNS but still answer IPP."""
        if device.mdns_services & cls._PRINTER_MDNS_SERVICES:
            return True
        if "wprt:PrintDeviceType" in device.wsd_services:
            return True
        if device.http_probe_results.get(631) == "ok" or 631 in device.http_banners:
            return True
        return False

    async def enrich_ipp(self):
        """Query printers for IPP Get-Printer-Attributes. Adds the model for
        mDNS-silent printers and the admin-set printer-info/-location that have
        no mDNS equivalent. Runs after the HTTP banner probe so the port-631
        signal in _looks_like_printer is available."""
        tasks = [
            self._fetch_ipp_attributes(d)
            for d in self.devices.values()
            if self._looks_like_printer(d)
        ]
        if tasks:
            await asyncio.gather(*tasks, return_exceptions=True)

    async def _fetch_ipp_attributes(self, device: Device, attempts: int = 3):
        """POST Get-Printer-Attributes to the printer and record the few
        naming/status fields we asked for. The queue path comes from the mDNS
        'rp' key when present, else the IPP Everywhere default of /ipp/print.
        Tries plain IPP on 631 first, then implicit-TLS ipps on 631.

        Retries a few times: this fires right after the concurrent banner sweep,
        and a printer that's momentarily busy will drop or stall the connection
        (an empty/truncated body parses to nothing). A silent miss here loses the
        model and admin info, so it's worth a couple of extra cheap attempts with
        timeouts more generous than the snappy banner grabs."""
        rp = (device.txt_records.get("rp") or "ipp/print").lstrip("/")
        path = "/" + rp
        for attempt in range(attempts):
            if attempt > 0:
                await asyncio.sleep(0.3)
            if await self._fetch_ipp_attributes_once(device, path):
                return

    async def _fetch_ipp_attributes_once(self, device: Device, path: str) -> bool:
        """One pass over the IPP endpoints; returns True if attributes were
        recorded so the caller can stop retrying."""
        for port, https in ((631, False), (631, True)):
            scheme = "ipps" if https else "ipp"
            printer_uri = f"{scheme}://{device.address}:{port}{path}"
            try:
                body = await self._http_post(
                    device.address, port, path,
                    _build_ipp_get_printer_attributes(printer_uri),
                    "application/ipp", is_https=https,
                    connect_timeout=2.0, read_timeout=4.0,
                )
            except Exception:
                continue
            attrs = _parse_ipp_response(body or b"")
            if not attrs:
                continue

            def first(name):
                vals = attrs.get(name)
                return vals[0] if vals else None

            mm = first("printer-make-and-model")
            info = first("printer-info")
            if isinstance(mm, str) and mm.strip():
                device.ipp_make_and_model = mm.strip()
            if isinstance(info, str) and info.strip():
                device.ipp_info = info.strip()
            # Flat snapshot for the detail view; render the state enum as a word.
            for name in ("printer-make-and-model", "printer-info",
                         "printer-location", "printer-state", "printer-state-reasons"):
                vals = attrs.get(name)
                if not vals:
                    continue
                if name == "printer-state":
                    rendered = [_IPP_PRINTER_STATES.get(v, str(v)) for v in vals]
                else:
                    rendered = [str(v) for v in vals]
                device.ipp_attrs[name] = ", ".join(r for r in rendered if r)
            if device.ipp_attrs:
                return True
        return False

    async def enrich_netbios(self, timeout: float = 0.5):
        """Send a NetBIOS Node Status query (NBSTAT) to every known device.

        Useful for naming Windows PCs, NAS units, and older printers that
        don't speak mDNS. Each query is a single unicast UDP packet to port
        137 — silent on devices that don't run NBNS, and very informative
        on the ones that do."""
        tasks = [self._query_netbios(d, timeout) for d in list(self.devices.values())]
        if tasks:
            await asyncio.gather(*tasks, return_exceptions=True)

    @staticmethod
    def _encode_netbios_name(name: bytes) -> bytes:
        """Encode a 16-byte raw NetBIOS name into its 32-byte wire form.
        Each byte is split into two nibbles, each added to 0x41 ('A')."""
        out = bytearray()
        for b in name:
            out.append(0x41 + (b >> 4))
            out.append(0x41 + (b & 0xF))
        return bytes(out)

    async def _query_netbios(self, device: Device, timeout: float):
        """Send NBSTAT (qtype 0x21) for the wildcard name '*' and parse the reply."""
        # Wildcard name: '*' + 15 NULs, encoded to 32 ASCII bytes ("CKAAAA...AAAA").
        raw_name = b"*" + b"\x00" * 15
        encoded = self._encode_netbios_name(raw_name)

        # 12-byte DNS-style header: trxid=0x1234, flags=0, qd=1, others=0
        header = struct.pack(">HHHHHH", 0x1234, 0, 1, 0, 0, 0)
        # Question: length-prefixed encoded name (32) + null terminator + qtype + qclass
        question = bytes([32]) + encoded + b"\x00" + struct.pack(">HH", 0x21, 0x0001)
        query = header + question

        loop = asyncio.get_running_loop()
        sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        sock.setblocking(False)
        try:
            try:
                await loop.sock_sendto(sock, query, (device.address, 137))
            except (AttributeError, NotImplementedError):
                # sock_sendto is 3.11+; fall back to blocking send on the
                # non-blocking socket (UDP sends complete immediately).
                try:
                    sock.sendto(query, (device.address, 137))
                except OSError:
                    return

            try:
                data = await asyncio.wait_for(loop.sock_recv(sock, 4096), timeout=timeout)
            except (asyncio.TimeoutError, OSError):
                return

            self._parse_nbstat_response(data, device)
        finally:
            sock.close()

    def _parse_nbstat_response(self, data: bytes, device: Device):
        """Parse an NBSTAT reply: header → [question]* → answer RR → name list.

        macOS smbd is RFC-noncompliant here: it responds with QDCOUNT=0 (no
        echoed question section) instead of the typical QDCOUNT=1. We honor
        the actual qdcount from the header rather than assuming a fixed shape."""
        if len(data) < 12:
            return
        # Header: id(2), flags(2), qd(2), an(2), ns(2), ar(2)
        qdcount, ancount = struct.unpack(">HH", data[4:8])
        if ancount == 0:
            return

        offset = 12
        # Skip whatever question sections are present (0 on macOS, 1 elsewhere)
        for _ in range(qdcount):
            _, offset = self._read_name(data, offset)
            offset += 4  # qtype + qclass

        # Answer RR: name + type(2) + class(2) + ttl(4) + rdlength(2) + rdata
        _, offset = self._read_name(data, offset)
        if offset + 10 > len(data):
            return
        offset += 10  # skip type/class/ttl/rdlength

        if offset >= len(data):
            return
        num_names = data[offset]
        offset += 1

        # Any well-formed NBSTAT reply is worth recording — macOS, for example,
        # responds with num_names=0 (no registered NetBIOS names) but the
        # response itself confirms the host runs an NBNS service.
        device.provenance.add("netbios")

        workstation: Optional[str] = None
        workgroup: Optional[str] = None

        for _ in range(num_names):
            if offset + 18 > len(data):
                break
            raw = data[offset:offset + 15].rstrip(b" \x00")
            suffix = data[offset + 15]
            flags = struct.unpack(">H", data[offset + 16:offset + 18])[0]
            is_group = bool(flags & 0x8000)
            offset += 18

            # Restrict to ASCII printable; macOS smbd has been seen returning
            # high-bit garbage in the workstation-name slot, and the unicode
            # replacement character `�` passes Python's isprintable().
            if not raw or not all(0x20 <= b <= 0x7E for b in raw):
                continue
            name = raw.decode("ascii")
            # Suffix 0x00 = workstation service (unique) or workgroup (group).
            # That's the one entry we care about for naming purposes.
            if suffix == 0x00:
                if is_group and not workgroup:
                    workgroup = name
                elif not is_group and not workstation:
                    workstation = name

        if workstation:
            device.netbios_name = workstation
        if workgroup:
            device.netbios_workgroup = workgroup

    # Ports probed by HTTP/HTTPS banner grab. Kept small on purpose — these
    # are the well-trodden web-admin ports; expanding the list runs into
    # diminishing returns and longer per-host probe time.
    _HTTP_BANNER_PORTS: tuple[tuple[int, bool], ...] = (
        (80, False),
        (8080, False),
        (8008, False),    # Chromecast / Cast web server
        (631, False),     # IPP printer admin UI
        (443, True),
        (8443, True),
    )

    async def enrich_http_banners(self, timeout: float = 1.0):
        """Probe a small set of HTTP/HTTPS ports on every device for Server
        header and <title>. Skips ports already covered by an SSDP LOCATION URL
        (same path, no point re-fetching)."""
        sem = asyncio.Semaphore(50)

        async def guarded(device: Device, port: int, is_https: bool):
            async with sem:
                await self._grab_http_banner(device, port, is_https, timeout)

        tasks = []
        for device in self.devices.values():
            covered_ports = set()
            for url in device.location_urls:
                p = urlparse(url)
                covered_ports.add(p.port or (443 if p.scheme == "https" else 80))
            for port, is_https in self._HTTP_BANNER_PORTS:
                if port in covered_ports:
                    continue
                tasks.append(guarded(device, port, is_https))
        if tasks:
            await asyncio.gather(*tasks, return_exceptions=True)

    async def _grab_http_banner(self, device: Device, port: int, is_https: bool, timeout: float):
        """Open the port, send GET /, harvest Server header + <title>.

        Always records a per-port outcome in device.http_probe_results
        (closed / timeout / non-http / ok) so the device-details view can
        report what actually happened on every port we tried."""
        try:
            if is_https:
                reader, writer = await asyncio.wait_for(
                    asyncio.open_connection(device.address, port,
                                            ssl=_unverified_tls_context()),
                    timeout=timeout,
                )
            else:
                reader, writer = await asyncio.wait_for(
                    asyncio.open_connection(device.address, port),
                    timeout=timeout,
                )
        except asyncio.TimeoutError:
            device.http_probe_results[port] = "timeout"
            return
        except Exception:
            device.http_probe_results[port] = "closed"
            return

        try:
            request = (
                f"GET / HTTP/1.0\r\n"
                f"Host: {device.address}\r\n"
                f"User-Agent: lan-scan\r\n"
                f"Accept: */*\r\n"
                f"Connection: close\r\n\r\n"
            )
            try:
                writer.write(request.encode())
                await asyncio.wait_for(writer.drain(), timeout=timeout)
            except Exception:
                # Connected but couldn't send — treat like a TCP service
                # that doesn't speak HTTP.
                device.http_probe_results[port] = "non-http"
                return

            chunks: list[bytes] = []
            total = 0
            deadline = asyncio.get_running_loop().time() + timeout * 2
            while True:
                remaining = deadline - asyncio.get_running_loop().time()
                if remaining <= 0:
                    break
                try:
                    chunk = await asyncio.wait_for(reader.read(4096), timeout=remaining)
                except (asyncio.TimeoutError, Exception):
                    break
                if not chunk:
                    break
                chunks.append(chunk)
                total += len(chunk)
                # Cap to keep memory bounded on devices that stream large pages.
                if total > 65536:
                    break

            response = b"".join(chunks)
            if not response:
                device.http_probe_results[port] = "non-http"
                return

            header_blob, _, body = response.partition(b"\r\n\r\n")
            header_text = header_blob.decode("iso-8859-1", errors="ignore")
            lines = header_text.split("\r\n")
            status_line = lines[0] if lines else ""

            # Require something that resembles an HTTP status line, so we
            # don't record a random TCP service that happens to write a few
            # bytes on accept. "HTTP/" is the minimum signal.
            if not status_line.startswith("HTTP/"):
                device.http_probe_results[port] = "non-http"
                return

            banner: dict[str, str] = {}
            try:
                parts = status_line.split(maxsplit=2)
                if len(parts) >= 2:
                    banner["status"] = parts[1]
            except (IndexError, ValueError):
                pass

            for line in lines[1:]:
                if line.lower().startswith("server:"):
                    banner["server"] = line.split(":", 1)[1].strip()[:200]
                    break

            if body:
                body_text = body.decode("utf-8", errors="ignore")
                m = re.search(r"<title[^>]*>([^<]+)</title>", body_text, re.IGNORECASE | re.DOTALL)
                if m:
                    title = m.group(1).strip()
                    title = (title
                             .replace("&amp;", "&")
                             .replace("&lt;", "<")
                             .replace("&gt;", ">")
                             .replace("&quot;", '"')
                             .replace("&#39;", "'"))
                    title = " ".join(title.split())  # collapse whitespace
                    if title:
                        banner["title"] = title[:200]

            # Record on any HTTP-shaped reply, even if the device only sent
            # back a status line. "HTTP service exists on port X" is itself
            # useful, even without Server header or page title.
            device.http_banners[port] = banner
            device.http_probe_results[port] = "ok"
        finally:
            try:
                writer.close()
            except Exception:
                pass

    async def _fetch_description(self, device: Device):
        """Fetch and parse UPnP device description XML from LOCATION URLs
        advertised in the device's SSDP responses."""
        for url in device.location_urls:
            try:
                parsed = urlparse(url)
                host = parsed.hostname
                port = parsed.port or (443 if parsed.scheme == "https" else 80)
                path = parsed.path or "/"
                if parsed.query:
                    path = f"{path}?{parsed.query}"
                if not host:
                    continue
                body = await self._http_get(host, port, path)
                if body and b"<" in body:
                    self._parse_device_xml(device, url, body)
            except Exception:
                continue

    async def _http_get(self, host: str, port: int, path: str) -> bytes:
        """Simple HTTP GET returning response body."""
        reader, writer = await asyncio.wait_for(
            asyncio.open_connection(host, port),
            timeout=1.0,
        )

        request = f"GET {path} HTTP/1.1\r\nHost: {host}\r\nConnection: close\r\n\r\n"
        writer.write(request.encode())
        await writer.drain()

        # Read until connection closes (we sent Connection: close)
        chunks = []
        try:
            while True:
                chunk = await asyncio.wait_for(reader.read(4096), timeout=2.0)
                if not chunk:
                    break
                chunks.append(chunk)
        except asyncio.TimeoutError:
            pass
        response = b"".join(chunks)
        writer.close()

        # Parse response body
        parts = response.split(b"\r\n\r\n", 1)
        body = parts[-1] if len(parts) > 1 else b""

        # Handle chunked transfer encoding
        if b"transfer-encoding: chunked" in parts[0].lower():
            body = self._decode_chunked(body)

        return body

    async def _http_post(self, host: str, port: int, path: str,
                         body: bytes, content_type: str,
                         is_https: bool = False,
                         connect_timeout: float = 1.0,
                         read_timeout: float = 2.0) -> bytes:
        """Simple HTTP POST returning the response body. Mirrors _http_get's
        connect/read/close + chunked-decode handling, with optional TLS for
        https/ipps endpoints (certs unverified — see _unverified_tls_context).
        Timeouts are tunable so slower binary endpoints (IPP) can wait longer
        than the snappy banner grabs."""
        ssl_ctx = _unverified_tls_context() if is_https else None
        reader, writer = await asyncio.wait_for(
            asyncio.open_connection(host, port, ssl=ssl_ctx),
            timeout=connect_timeout,
        )

        head = (
            f"POST {path} HTTP/1.1\r\n"
            f"Host: {host}\r\n"
            f"Content-Type: {content_type}\r\n"
            f"Content-Length: {len(body)}\r\n"
            f"Connection: close\r\n\r\n"
        ).encode()
        writer.write(head + body)
        await writer.drain()

        chunks = []
        try:
            while True:
                chunk = await asyncio.wait_for(reader.read(4096), timeout=read_timeout)
                if not chunk:
                    break
                chunks.append(chunk)
        except asyncio.TimeoutError:
            pass
        response = b"".join(chunks)
        writer.close()

        parts = response.split(b"\r\n\r\n", 1)
        resp_body = parts[-1] if len(parts) > 1 else b""
        if b"transfer-encoding: chunked" in parts[0].lower():
            resp_body = self._decode_chunked(resp_body)
        return resp_body

    def _decode_chunked(self, data: bytes) -> bytes:
        """Decode HTTP chunked transfer encoding."""
        decoded = []
        pos = 0
        while pos < len(data):
            # Find the end of the chunk size line
            line_end = data.find(b"\r\n", pos)
            if line_end == -1:
                break
            # Parse chunk size (hex)
            try:
                chunk_size = int(data[pos:line_end].split(b";")[0], 16)
            except ValueError:
                break
            if chunk_size == 0:
                break
            # Extract chunk data
            chunk_start = line_end + 2
            chunk_end = chunk_start + chunk_size
            if chunk_end > len(data):
                decoded.append(data[chunk_start:])
                break
            decoded.append(data[chunk_start:chunk_end])
            pos = chunk_end + 2  # Skip trailing \r\n
        return b"".join(decoded)

    def _parse_device_xml(self, device: Device, url: str, xml_data: bytes):
        """Parse UPnP device description XML for friendly name and model."""
        # Store raw XML for detail view — one entry per source URL since a
        # single device may advertise several distinct LOCATIONs.
        device.xml_data[url] = xml_data
        try:
            # Handle potential BOM or whitespace
            xml_data = xml_data.strip()
            if xml_data.startswith(b'\xef\xbb\xbf'):
                xml_data = xml_data[3:]

            root = ET.fromstring(xml_data)

            # Extract namespace from root tag if present
            namespaces = ["{urn:schemas-upnp-org:device-1-0}", ""]

            friendly_name = None
            model_name = None
            room_name = None
            device_type = None

            # Try each namespace
            for ns in namespaces:
                # Look for device element
                device_elem = root.find(f".//{ns}device")
                if device_elem is not None:
                    friendly_name = friendly_name or device_elem.findtext(f"{ns}friendlyName")
                    model_name = model_name or device_elem.findtext(f"{ns}modelName")
                    room_name = room_name or device_elem.findtext(f"{ns}roomName")
                    device_type = device_type or device_elem.findtext(f"{ns}deviceType")

            xml_str = xml_data.decode("utf-8", errors="ignore")

            # Fallback: extract with simple string parsing if ET didn't find values
            if not friendly_name:
                match = re.search(r"<friendlyName>([^<]+)</friendlyName>", xml_str)
                if match:
                    friendly_name = match.group(1)
            if not model_name:
                match = re.search(r"<modelName>([^<]+)</modelName>", xml_str)
                if match:
                    model_name = match.group(1)
            if not room_name:
                match = re.search(r"<roomName>([^<]+)</roomName>", xml_str)
                if match:
                    room_name = match.group(1)
            if not device_type:
                match = re.search(r"<deviceType>([^<]+)</deviceType>", xml_str)
                if match:
                    device_type = match.group(1)

            # Also look for manufacturer
            manufacturer = None
            for ns in namespaces:
                device_elem = root.find(f".//{ns}device")
                if device_elem is not None:
                    manufacturer = device_elem.findtext(f"{ns}manufacturer")
                    if manufacturer:
                        break
            if not manufacturer:
                match = re.search(r"<manufacturer>([^<]+)</manufacturer>", xml_str)
                if match:
                    manufacturer = match.group(1)

            # Apply values to the per-source name fields; resolve_name picks
            # one at display time according to the documented priority list.
            if friendly_name:
                device.upnp_friendly_name = friendly_name
            if room_name:
                device.upnp_room_name = room_name
            if manufacturer:
                device.upnp_manufacturer = manufacturer
            if model_name:
                device.model = model_name
            if device_type and not device.upnp_device_type:
                device.upnp_device_type = device_type

        except Exception:
            pass

    def populate_mac_addresses(self):
        """Populate MAC addresses and registrants for all devices."""
        self.arp_table = get_arp_table()
        for device in self.devices.values():
            if device.address in self.arp_table:
                device.mac_address = self.arp_table[device.address]
                device.oui_registrant = lookup_oui_registrant(device.mac_address)

    def _get_local_ip(self) -> Optional[str]:
        """Determine the local IP by opening a UDP socket to a public address.

        No packets are actually sent — connect() on a UDP socket just selects
        the route, which lets us read back the outbound interface address.
        """
        try:
            sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            sock.connect(("8.8.8.8", 80))
            ip = sock.getsockname()[0]
            sock.close()
            return ip
        except Exception:
            return None

    def _detect_subnet(self) -> Optional[tuple[str, str]]:
        """Return (real_subnet, sweep_subnet) as CIDR strings, or None if the
        local IP can't be determined.

        real_subnet is the interface's actual network (for the status bar and
        diff identity); its prefix is read from the OS interface table (via
        `ip` on Linux or `ifconfig` on macOS/BSD), falling back to /24.

        sweep_subnet is what the nmap ARP sweep targets: the same network, but
        with the prefix floored at ARP_SWEEP_MAX_PREFIX so a wide mask collapses
        to a /22-aligned window around the local IP rather than blasting tens of
        thousands of mostly-unreachable ARP probes. Both are derived from a
        single IP read so they stay consistent with each other.
        """
        local_ip = self._get_local_ip()
        if not local_ip:
            return None
        prefix = self._get_local_prefixlen(local_ip)
        if prefix is None:
            prefix = 24
        real = ipaddress.ip_network(f"{local_ip}/{prefix}", strict=False)
        sweep = ipaddress.ip_network(
            f"{local_ip}/{max(prefix, ARP_SWEEP_MAX_PREFIX)}", strict=False
        )
        return str(real), str(sweep)

    def _get_local_subnet(self) -> Optional[str]:
        """The interface's actual subnet in CIDR form (e.g. '192.168.1.0/24')."""
        detected = self._detect_subnet()
        return detected[0] if detected else None

    def _arp_sweep_subnet(self) -> Optional[str]:
        """The CIDR handed to the nmap ARP sweep (capped — see _detect_subnet).

        This value is also baked into the sudoers NOPASSWD entry, so every call
        site that builds the nmap command must go through here (or _detect_subnet)
        or `sudo -n` won't match the command and the sweep fails."""
        detected = self._detect_subnet()
        return detected[1] if detected else None

    def _get_local_prefixlen(self, local_ip: str) -> Optional[int]:
        """Find the network prefix length for the interface that owns
        ``local_ip`` by parsing the platform's interface listing. Returns
        None if it can't be determined (caller falls back to /24)."""
        # Linux: `ip -o -f inet addr show` → "... inet 192.168.1.23/24 ..."
        ip_path = shutil.which("ip")
        if ip_path:
            try:
                out = subprocess.run(
                    [ip_path, "-o", "-f", "inet", "addr", "show"],
                    capture_output=True, text=True, timeout=2.0,
                ).stdout
                m = re.search(rf"inet {re.escape(local_ip)}/(\d+)", out)
                if m:
                    return int(m.group(1))
            except Exception:
                pass
        # macOS/BSD: `ifconfig` → "inet 192.168.1.23 netmask 0xffffff00 ..."
        ifconfig_path = shutil.which("ifconfig")
        if ifconfig_path:
            try:
                out = subprocess.run(
                    [ifconfig_path], capture_output=True, text=True, timeout=2.0,
                ).stdout
                m = re.search(
                    rf"inet {re.escape(local_ip)}\s+netmask\s+(\S+)", out
                )
                if m:
                    return self._netmask_to_prefixlen(m.group(1))
            except Exception:
                pass
        return None

    @staticmethod
    def _netmask_to_prefixlen(netmask: str) -> Optional[int]:
        """Convert a netmask to a prefix length. Accepts both the hex form
        BSD/macOS `ifconfig` prints (e.g. '0xffffff00') and dotted-quad
        (e.g. '255.255.255.0'). Returns None if it can't be parsed."""
        try:
            if netmask.lower().startswith("0x"):
                value = int(netmask, 16)
            else:
                value = int(ipaddress.IPv4Address(netmask))
        except (ValueError, ipaddress.AddressValueError):
            return None
        prefix = bin(value).count("1")
        # Reject non-contiguous masks (count of set bits wouldn't be meaningful).
        if value != (((1 << prefix) - 1) << (32 - prefix)):
            return None
        return prefix

    async def discover_arp(self) -> Optional[str]:
        """Active ARP scan via `sudo -n nmap`.

        Returns None on success, or a short reason string explaining why the
        scan was skipped (so the caller can surface it to the user).
        """
        detected = self._detect_subnet()
        if not detected:
            self.subnet = None
            return "no local subnet"
        # self.subnet is the real subnet (TUI status bar / diff); nmap targets
        # the possibly-capped sweep window — see _detect_subnet.
        self.subnet, sweep = detected

        nmap_path = shutil.which("nmap")
        if not nmap_path:
            return "nmap not installed (brew install nmap)"

        try:
            proc = await asyncio.create_subprocess_exec(
                "sudo", "-n", nmap_path, "-sn", "-PR", "-oG", "-", sweep,
                stdout=asyncio.subprocess.PIPE,
                stderr=asyncio.subprocess.DEVNULL,
            )
        except Exception:
            return "could not run sudo nmap"

        # Scale the timeout with the swept subnet size: 10s for a /24 (or
        # narrower), doubling per bit wider — e.g. /23 → 20s, /22 → 40s.
        prefixlen = ipaddress.ip_network(sweep, strict=False).prefixlen
        sweep_timeout = 10 * 2 ** max(0, 24 - prefixlen)

        try:
            stdout, _ = await asyncio.wait_for(proc.communicate(), timeout=sweep_timeout)
        except asyncio.TimeoutError:
            proc.kill()
            await proc.wait()
            return "nmap timed out"

        if proc.returncode != 0:
            return "sudo not configured (run --setup-sudoers)"

        # Greppable format: "Host: 192.168.1.1 (hostname)\tStatus: Up"
        for line in stdout.decode("utf-8", errors="ignore").splitlines():
            if not line.startswith("Host:") or "Status: Up" not in line:
                continue
            parts = line.split()
            if len(parts) >= 2:
                self.add_device(parts[1], source="arp")

        # MACs/OUIs get populated centrally by populate_mac_addresses() after
        # all discovery stages complete — nmap has already refreshed the kernel
        # ARP cache by the time we return here.
        return None

    async def populate_rdns(self, timeout: float = 2.0):
        """Run reverse DNS lookups for all devices in parallel."""
        loop = asyncio.get_running_loop()

        async def lookup(device: Device):
            try:
                name, _ = await asyncio.wait_for(
                    loop.getnameinfo((device.address, 0), 0),
                    timeout=timeout,
                )
                # getnameinfo returns the IP literal if no PTR exists
                if name and name != device.address:
                    device.rdns_name = name
            except (asyncio.TimeoutError, socket.gaierror, OSError):
                pass

        await asyncio.gather(
            *(lookup(d) for d in self.devices.values()),
            return_exceptions=True,
        )

    async def discover(self, timeout: float = 3.0, on_progress: Optional[Callable[..., None]] = None):
        """Run all discovery methods concurrently, reporting per-stage progress."""
        def report(msg: str, key: Optional[str] = None, final: bool = False):
            # key: when set, the consumer may rewrite the line with the same key
            # in place (used for the live per-stage counters). final: marks the
            # last update for a key, so plain-stdout consumers can skip the
            # intermediate ticks and print only the settled line.
            if on_progress:
                on_progress(msg, key=key, final=final)

        def count_by(*sources: str) -> int:
            return sum(
                1 for d in self.devices.values() if any(s in d.provenance for s in sources)
            )

        # The three multicast scans accrue devices into self.devices as packets
        # arrive, so their counters can climb live; ARP is an external nmap
        # sweep that lands all at once, so it just shows "..." until done.
        # `done` keeps the ticker from clobbering a stage's settled final line.
        live_stages = {"mDNS scan": ("mdns",), "SSDP scan": ("ssdp",),
                       "WS-Discovery": ("wsd",)}
        done: set[str] = set()

        async def stage(label: str, coro, *sources: str):
            start = time.monotonic()
            await coro
            elapsed = time.monotonic() - start
            n = count_by(*sources)
            done.add(label)
            report(f"  {label:<22} {n:>3} {plural(n, 'host')}  ({elapsed:.1f}s)",
                   key=label, final=True)

        async def arp_stage():
            start = time.monotonic()
            skip_reason = await self.discover_arp()
            elapsed = time.monotonic() - start
            done.add("ARP scan")
            if skip_reason:
                report(f"  {'ARP scan':<22} skipped — {skip_reason}",
                       key="ARP scan", final=True)
            else:
                n = count_by('arp')
                report(f"  {'ARP scan':<22} {n:>3} {plural(n, 'host')}  ({elapsed:.1f}s)",
                       key="ARP scan", final=True)

        async def ticker():
            """Poll device counts ~5×/s and rewrite each in-progress stage's
            line. Pure UI sugar — it never touches discovery state."""
            try:
                while True:
                    await asyncio.sleep(0.2)
                    for label, sources in live_stages.items():
                        if label in done:
                            continue
                        n = count_by(*sources)
                        if n:
                            report(f"  {label:<22} {n:>3} {plural(n, 'host')}...",
                                   key=label)
            except asyncio.CancelledError:
                pass

        report("Discovery:")
        discovery_start = time.monotonic()
        # Lay down all four stage lines up front (fixed row order) so the ticker
        # has stable rows to rewrite as counts come in.
        for label in ("mDNS scan", "SSDP scan", "WS-Discovery", "ARP scan"):
            # Blank count + blank "hosts" so the "..." lands in the same column
            # as the trailing dots of the live "N hosts..." line below.
            report(f"  {label:<22} {'':>3} {'':<5}...", key=label)

        ticker_task = asyncio.create_task(ticker())
        try:
            await asyncio.gather(
                stage("mDNS scan", self.discover_mdns(timeout), "mdns"),
                stage("SSDP scan", self.discover_ssdp(timeout), "ssdp"),
                stage("WS-Discovery", self.discover_wsd(timeout), "wsd"),
                arp_stage(),
            )
        finally:
            ticker_task.cancel()
            await ticker_task

        total = len(self.devices)
        report(f"  → {total} unique {plural(total, 'host')}  ({time.monotonic() - discovery_start:.1f}s)")

        report("")
        report("Enrichment:")

        start = time.monotonic()
        await self.fetch_device_descriptions()
        described = sum(1 for d in self.devices.values() if d.xml_data)
        report(f"  UPnP descriptions      {described:>3} fetched   ({time.monotonic() - start:.1f}s)")

        start = time.monotonic()
        await self.enrich_wsd()
        wsd_n = sum(1 for d in self.devices.values()
                    if d.wsd_model or d.wsd_friendly_name or d.wsd_manufacturer)
        if wsd_n:
            report(f"  WSD metadata           {wsd_n:>3} resolved  ({time.monotonic() - start:.1f}s)")

        # Catch devices found via mDNS/SSDP that the arp sweep missed
        # fill in vendors for MAC addresses before vendor-specific probes
        self.populate_mac_addresses()

        start = time.monotonic()
        await self.enrich_roku()
        roku_n = sum(1 for d in self.devices.values() if d.roku_info)
        if roku_n:
            report(f"  Roku ECP               {roku_n:>3} enriched  ({time.monotonic() - start:.1f}s)")

        start = time.monotonic()
        await self.enrich_hue()
        hue_n = sum(1 for d in self.devices.values() if d.hue_info)
        if hue_n:
            report(f"  Hue /api/config        {hue_n:>3} enriched  ({time.monotonic() - start:.1f}s)")

        start = time.monotonic()
        await self.enrich_netbios()
        nb_n = sum(1 for d in self.devices.values() if d.netbios_name or d.netbios_workgroup)
        report(f"  NetBIOS names          {nb_n:>3} named     ({time.monotonic() - start:.1f}s)")

        start = time.monotonic()
        await self.enrich_http_banners()
        http_n = sum(1 for d in self.devices.values() if d.http_banners)
        report(f"  HTTP banners           {http_n:>3} gathered  ({time.monotonic() - start:.1f}s)")

        # After HTTP banners so _looks_like_printer can use the port-631 signal.
        start = time.monotonic()
        await self.enrich_ipp()
        ipp_n = sum(1 for d in self.devices.values() if d.ipp_attrs)
        if ipp_n:
            report(f"  IPP attributes         {ipp_n:>3} queried   ({time.monotonic() - start:.1f}s)")

        start = time.monotonic()
        await self.populate_rdns()
        resolved = sum(1 for d in self.devices.values() if d.rdns_name)
        report(f"  Reverse DNS            {resolved:>3} resolved  ({time.monotonic() - start:.1f}s)")

    def print_results(self):
        """Print discovered devices in a formatted table."""
        print("\n" + "=" * 90)
        print(f"{'ADDRESS':15} | {'DEVICE':40} | SERVICES")
        print("-" * 90)

        for device in sorted(self.devices.values(), key=lambda d: tuple(map(int, d.address.split(".")))):
            print(device)

        print("=" * 90)
        print(f"Found {len(self.devices)} device(s)\n")


# Folder icon used to mark <device> nodes in the UPnP tree. The renderer
# uses presence of this glyph on a line to apply bold styling, so it must
# be unique to device-node lines.
UPNP_DEVICE_ICON = "\u2699\ufe0f"  # ⚙️ (gear U+2699 + emoji-presentation selector U+FE0F)
# Lines starting with this byte get rendered with A_DIM (greyed). Used by the
# probe-status block to fade out negative results so the eye snaps to the
# rows with actual data.
DIM_LINE_MARKER = "\x01"


def _upnp_short(urn: str, kind: str) -> str:
    """Extract short name from a UPnP URN, e.g.
    urn:schemas-upnp-org:device:WANDevice:1 -> WANDevice."""
    parts = (urn or "").split(":")
    for i, p in enumerate(parts):
        if p == kind and i + 1 < len(parts):
            return parts[i + 1]
    return urn or kind


def _strip_xml_namespaces(root: ET.Element) -> None:
    for elem in root.iter():
        if "}" in elem.tag:
            elem.tag = elem.tag.split("}", 1)[1]


def _render_upnp_device(
    elem: ET.Element,
    lines: list[str],
    prefix: str,
    is_last: bool,
    is_root: bool,
) -> None:
    """Recursively render a UPnP <device> node and its services/sub-devices."""
    label = _upnp_short(elem.findtext("deviceType") or "", "device")
    if is_root:
        lines.append(f"{UPNP_DEVICE_ICON}  {label}")
        # Root's connectors get a 1-cell leading space (via the connector
        # itself) so the tree spine sits just inside column 0 rather than
        # flush against it.
        child_prefix = ""
    else:
        connector = " └── " if is_last else " ├── "
        lines.append(f"{prefix}{connector}{UPNP_DEVICE_ICON}  {label}")
        # 5-cell continuation matches the connector width (" ├── "), so
        # the next level's connector lines up directly under this level's.
        child_prefix = prefix + ("     " if is_last else " │   ")

    service_list = elem.find("serviceList")
    services = [s for s in service_list if s.tag == "service"] if service_list is not None else []

    device_list = elem.find("deviceList")
    sub_devices = [d for d in device_list if d.tag == "device"] if device_list is not None else []

    total = len(services) + len(sub_devices)

    for i, svc in enumerate(services):
        last = (i == total - 1)
        connector = " └── " if last else " ├── "
        name = _upnp_short(svc.findtext("serviceType") or "", "service")
        lines.append(f"{child_prefix}{connector}{name}")

    for j, dev in enumerate(sub_devices):
        last = (len(services) + j == total - 1)
        _render_upnp_device(dev, lines, child_prefix, last, is_root=False)


def format_xml(xml_data: bytes) -> list[str]:
    """Format a UPnP device description XML for display.

    Emits the root device's metadata (friendly name, manufacturer, etc.),
    a blank line, then a hierarchical tree of nested <device>/<service>
    elements. Device-node lines are prefixed with UPNP_DEVICE_ICON so the
    renderer can render them in bold.
    """
    lines: list[str] = []
    try:
        xml_data = xml_data.strip()
        if xml_data.startswith(b"\xef\xbb\xbf"):
            xml_data = xml_data[3:]

        root = ET.fromstring(xml_data)
        _strip_xml_namespaces(root)

        root_device = root.find("device")
        if root_device is None:
            return ["(no <device> element in description)"]

        # Render every text-bearing scalar child of <device> in document order,
        # using the raw schema tag names. The UPnP Device Description schema is
        # well-defined enough — and the extension-point convention loose enough
        # — that vendor extras like Sonos's `roomName`, `displayVersion`,
        # `swGen`, `internalSpeakerSize` land alongside the standard elements;
        # iterating gets them all without a per-vendor allow-list. Container
        # elements (serviceList, deviceList, iconList) have no direct text so
        # are filtered out naturally.
        for child in root_device:
            if child.text and child.text.strip():
                lines.append(f"{child.tag}: {child.text.strip()}")

        if lines:
            lines.append("")

        _render_upnp_device(root_device, lines, prefix="", is_last=True, is_root=True)

    except Exception as e:
        lines.append(f"Error parsing XML: {e}")
        try:
            raw = xml_data.decode("utf-8", errors="ignore")
            for line in raw.split("\n")[:50]:
                lines.append(line.rstrip())
        except Exception:
            pass

    return lines


def _format_probe_status(device: Device) -> list[str]:
    """One-line-per-probe status block for the device-details popup.

    Reports, for every probe type the scanner runs:
      - whether the probe was eligible / attempted
      - what came back (counts) or why it returned nothing

    Replaces the older `Discovered via:` / `Also replied to:` split and the
    `Checked: ...` fallback — both of which only surfaced partial status.
    """
    lines: list[str] = []

    def add(label: str, status: str, dim: bool = False):
        # 12-char column fits the longest label ("HTTP banners" / "WS-Discovery").
        # The leading DIM_LINE_MARKER tells the renderer to draw this row with
        # A_DIM so negative/uninteresting probe results fade visually.
        prefix = DIM_LINE_MARKER if dim else ""
        lines.append(f"{prefix}  {label:<12} : {status}")

    # ARP — active sweep via `sudo nmap -sn -PR <subnet>`. If the device
    # responded to the unicast ARP probe it shows up here; otherwise it was
    # found by one of the other discovery protocols (or the ARP sweep was
    # skipped because nmap/sudo weren't configured).
    if "arp" in device.provenance:
        add("ARP", "responded")
    else:
        add("ARP", "no response", dim=True)

    # mDNS — multicast discovery is always sent; per-host TXT queries follow.
    if "mdns" in device.provenance:
        bits: list[str] = []
        if device.mdns_services:
            n = len(device.mdns_services)
            bits.append(f"{n} {plural(n, 'service')}")
        if device.txt_records:
            n = len(device.txt_records)
            bits.append(f"{n} TXT {plural(n, 'record')}")
        add("mDNS", ", ".join(bits) if bits else "replied, no services or TXT records")
    else:
        add("mDNS", "no response", dim=True)

    # SSDP / UPnP — multicast M-SEARCH, then per-LOCATION-URL XML fetch.
    if "ssdp" in device.provenance:
        bits = []
        if device.ssdp_services:
            n = len(device.ssdp_services)
            bits.append(f"{n} {plural(n, 'service')}")
        if device.location_urls:
            n_urls = len(device.location_urls)
            n_fetched = len(device.xml_data)
            fetched = f"{n_fetched}/{n_urls} fetched" if n_fetched else "none fetched"
            bits.append(f"{n_urls} LOCATION {plural(n_urls, 'URL')} ({fetched})")
        add("SSDP", ", ".join(bits) if bits else "replied, no services or LOCATION URLs")
    else:
        add("SSDP", "no response", dim=True)

    # WS-Discovery — multicast probe, optional response with Types + XAddrs.
    if "wsd" in device.provenance:
        bits = []
        if device.wsd_services:
            n = len(device.wsd_services)
            bits.append(f"{n} {plural(n, 'type')}")
        if device.wsd_xaddrs:
            n = len(device.wsd_xaddrs)
            bits.append(f"{n} {plural(n, 'endpoint')}")
        if device.wsd_model or device.wsd_friendly_name or device.wsd_manufacturer:
            bits.append("metadata resolved")
        elif device.wsd_xaddrs:
            bits.append("metadata query empty")
        add("WS-Discovery", ", ".join(bits) if bits else "replied, no types or endpoints")
    else:
        add("WS-Discovery", "no response", dim=True)

    # NetBIOS — always queried per-device. A valid NBSTAT reply may register
    # names or be empty (macOS smbd does the latter).
    if "netbios" in device.provenance:
        bits = []
        if device.netbios_name:
            bits.append(f"name={device.netbios_name}")
        if device.netbios_workgroup:
            bits.append(f"workgroup={device.netbios_workgroup}")
        add("NetBIOS", ", ".join(bits) if bits else "replied, no names registered")
    else:
        add("NetBIOS", "no response", dim=True)

    # Roku ECP — only attempted on devices that look like a Roku.
    if device.roku_info:
        n = len(device.roku_info)
        add("Roku ECP", f"{n} {plural(n, 'field')}")
    elif NetworkDiscovery._looks_like_roku(device):
        add("Roku ECP", "queried, no info returned", dim=True)
    else:
        add("Roku ECP", "n/a", dim=True)

    # Philips Hue /api/config — only attempted on devices that look like a Hue bridge.
    if device.hue_info:
        n = len(device.hue_info)
        add("Hue config", f"{n} {plural(n, 'field')}")
    elif NetworkDiscovery._looks_like_hue(device):
        add("Hue config", "queried, no info returned", dim=True)
    else:
        add("Hue config", "n/a", dim=True)

    # IPP Get-Printer-Attributes — only attempted on devices that look like a printer.
    if device.ipp_attrs:
        n = len(device.ipp_attrs)
        add("IPP", f"{n} {plural(n, 'attribute')}")
    elif NetworkDiscovery._looks_like_printer(device):
        add("IPP", "queried, no attributes returned", dim=True)
    else:
        add("IPP", "n/a", dim=True)

    # HTTP banners — TCP probe of a fixed port list on every device. The
    # http_probe_results dict records every attempt's outcome, even failures.
    if device.http_probe_results:
        ok_ports = sorted(p for p, s in device.http_probe_results.items() if s == "ok")
        n_total = len(device.http_probe_results)
        n_ok = len(ok_ports)
        if n_ok:
            add("HTTP banners",
                f"{n_ok}/{n_total} responded ({', '.join(str(p) for p in ok_ports)})")
        else:
            # Break down the failure modes so it's clear *why* nothing came back.
            counts: dict[str, int] = {}
            for s in device.http_probe_results.values():
                counts[s] = counts.get(s, 0) + 1
            parts = [f"{counts[k]} {k}" for k in ("closed", "timeout", "non-http") if counts.get(k)]
            add("HTTP banners", f"0/{n_total} responded ({', '.join(parts)})", dim=True)
    else:
        add("HTTP banners", "not attempted", dim=True)

    return lines


